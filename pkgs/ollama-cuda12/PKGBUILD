# NOTE: This split PKGBUILD is for CUDA 12 only.
# - Requires CUDA major version 12 at /opt/cuda
# - Requires gcc14 for CUDA 12 toolchain compatibility

pkgbase=ollama
pkgname=(ollama ollama-cuda12 ollama-docs)
pkgver='0.17.4'
pkgrel=1
pkgdesc='Create, run and share large language models (LLMs)'
arch=(x86_64)
url='https://github.com/ollama/ollama'
license=(MIT)
options=('!lto')
depends=(gcc-libs glibc)
makedepends=(cmake
             ninja
             git
             go
             gcc14
             rocm-toolchain
             rocm-hip-sdk
             hipblas
             cuda
             clblast
             vulkan-headers
             vulkan-icd-loader
             shaderc)
source=(git+https://github.com/ollama/ollama#tag=v$pkgver
        ollama-ld.conf
        ollama.service
        sysusers.conf
        tmpfiles.d)
b2sums=('f7bc510db94267ee296332fbb255f923fc4635682f935983ca31da0b05188d4f20f14a3ec11f5b936fa7a17d7ba88e79c01e47eb16aeeae8d8c22c855828b822'
        '121a7854b5a7ffb60226aaf22eed1f56311ab7d0a5630579525211d5c096040edbcfd2608169a4b6d83e8b4e4855dbb22f8ebf3d52de78a34ea3d4631b7eff36'
        '031e0809a7f564de87017401c83956d43ac29bd0e988b250585af728b952a27d139b3cad0ab1e43750e2cd3b617287d3b81efc4a70ddd61709127f68bd15eabd'
        '68622ac2e20c1d4f9741c57d2567695ec7b5204ab43356d164483cd3bc9da79fad72489bb33c8a17c2e5cb3b142353ed5f466ce857b0f46965426d16fb388632'
        'e8f2b19e2474f30a4f984b45787950012668bf0acb5ad1ebb25cd9776925ab4a6aa927f8131ed53e35b1c71b32c504c700fe5b5145ecd25c7a8284373bb951ed')

_cuda_build_dir="build-cuda12"

_require_cuda12() {
  if [[ ! -x "/opt/cuda/bin/nvcc" ]]; then
    printf '==> ERROR: %s\n' "nvcc not found at /opt/cuda/bin/nvcc" >&2
    printf '==> ERROR: %s\n' "Install CUDA 12 before building ollama-cuda12" >&2
    return 1
  fi

  local cuda_major
  cuda_major=$(/opt/cuda/bin/nvcc --version | sed -n 's/.*release \([0-9]*\)\..*/\1/p')
  echo "==> Detected CUDA version: ${cuda_major} at /opt/cuda"
  if [[ "${cuda_major}" -ne 12 ]]; then
    printf '==> ERROR: %s\n' "ollama-cuda12 requires CUDA major version 12 (detected: ${cuda_major})" >&2
    printf '==> ERROR: %s\n' "Use ollama-cuda13 with CUDA 13+" >&2
    return 1
  fi

  if ! command -v gcc-14 >/dev/null 2>&1; then
    printf '==> ERROR: %s\n' "CUDA 12 requires gcc14 but it's not installed" >&2
    printf '==> ERROR: %s\n' "Install with: sudo pacman -S gcc14" >&2
    return 1
  fi

  if [[ ! -d "/opt/cuda/targets/x86_64-linux/include/thrust" ]]; then
    printf '==> ERROR: %s\n' "CCCL headers are missing from CUDA 12 installation" >&2
    printf '==> ERROR: %s\n' "Expected: /opt/cuda/targets/x86_64-linux/include/thrust" >&2
    return 1
  fi
}

build() {
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOPATH="${srcdir}"
  export GOFLAGS="-buildmode=pie -mod=readonly -modcacherw '-ldflags=-linkmode=external -compressdwarf=false -X=github.com/ollama/ollama/version.Version=$pkgver -X=github.com/ollama/ollama/server.mode=release'"

  _require_cuda12

  export PATH="/opt/cuda/bin:${PATH}"
  export CUDA_PATH="/opt/cuda"
  export LD_LIBRARY_PATH="/opt/cuda/lib64:${LD_LIBRARY_PATH:-}"
  export CC=gcc-14
  export CXX=g++-14
  export CUDAHOSTCXX=g++-14
  printf '  -> %s\n' "Using GCC 14 for CUDA 12 compatibility"

  cd ollama

  # Remove the runtime dependencies from installation so CMake doesn't install
  # lots of system dependencies into the target path.
  sed -i 's/PRE_INCLUDE_REGEXES.*/PRE_INCLUDE_REGEXES = ""/' CMakeLists.txt

  # Common CMake options
  local cmake_base_options=(
    -G Ninja
    -W no-dev
    -D CMAKE_BUILD_TYPE=Release
    -D CMAKE_INSTALL_PREFIX=/usr
  )

  printf '  -> %s\n' "Building CUDA 12 variant..."
  printf '  -> %s\n' "Architectures: 50 (Maxwell), 52, 53, 60 (Pascal), 61, 62, 70 (Volta), 72, 75 (Turing), 80 (Ampere), 86, 87, 89, 90 (Hopper), 90a"

  local cmake_cuda_options=(
    "${cmake_base_options[@]}"
    -B "$_cuda_build_dir"
    -D CMAKE_CUDA_COMPILER=/opt/cuda/bin/nvcc
    -D CMAKE_HIP_COMPILER=OFF
    -D CMAKE_CUDA_ARCHITECTURES="50;52;53;60;61;62;70;72;75;80;86;87;89;90;90a"
    -D CMAKE_CUDA_FLAGS="-Wno-deprecated-gpu-targets"
  )
  rm -rf -- "$_cuda_build_dir"
  cmake "${cmake_cuda_options[@]}"
  cmake --build "$_cuda_build_dir"

  # Build main ollama binary
  go build .
}

check() {
  ollama/ollama --version > /dev/null
  cd ollama
  go test .
}

package_ollama() {
  _require_cuda12

  local build_dir="ollama/${_cuda_build_dir}"
  [[ -d "$build_dir" ]] || { printf '==> ERROR: %s\n' "Missing build dir: $build_dir" >&2; return 1; }

  DESTDIR="$pkgdir" cmake --install "$build_dir" --component CPU

  install -Dm755 ollama/ollama "$pkgdir/usr/bin/ollama"
  install -dm755 "$pkgdir/var/lib/ollama"
  install -Dm644 ollama.service "$pkgdir/usr/lib/systemd/system/ollama.service"
  install -Dm644 sysusers.conf "$pkgdir/usr/lib/sysusers.d/ollama.conf"
  install -Dm644 tmpfiles.d "$pkgdir/usr/lib/tmpfiles.d/ollama.conf"
  install -Dm644 ollama/LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

  ln -s /var/lib/ollama "$pkgdir/usr/share/ollama"
}

package_ollama-cuda12() {
  pkgdesc='CUDA 12 support for Ollama (Maxwell, Pascal, Volta, Turing, Ampere, Hopper)'
  depends=(ollama cuda)
  provides=(ollama-cuda)
  conflicts=(ollama-cuda13)

  _require_cuda12

  DESTDIR="$pkgdir" cmake --install "ollama/$_cuda_build_dir" --component CUDA
}

package_ollama-docs() {
  pkgdesc='Documentation for Ollama'

  install -d "$pkgdir/usr/share/doc"
  cp -r ollama/docs "$pkgdir/usr/share/doc/ollama"
  install -Dm644 ollama/LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
