# Maintainer: Okiki <okiki@thunderstrike.co>

pkgname=youki
pkgver=0.6.0
pkgrel=1
pkgdesc='A container runtime written in Rust'
arch=('x86_64')
url='https://youki-dev.github.io/youki'
license=('Apache-2.0')
depends=('dbus' 'gcc-libs' 'libseccomp')
makedepends=('git' 'dbus-glib' 'rust' 'systemd')
optdepends=(
  'docker: for docker runtime support'
  'podman: for podman runtime support'
)
source=("git+https://github.com/youki-dev/youki.git#tag=v$pkgver")
sha256sums=('67a67305474279f01b986054ffe318628100ca87d59d021603bfa8cf04827cf9')

prepare() {
  cd "${srcdir}/youki"

  # create directory for build artifacts
  mkdir -p build

  # download dependencies
  cargo fetch --locked --target "$(rustc --print host-tuple)"
}

build() {
  cd "${srcdir}/youki"

  cargo build --frozen --release --bin youki

  # generate shell completions
  for shell in bash fish zsh; do
    ./target/release/youki completion --shell "${shell}" > "target/$shell-completion"
  done
}

check() {
  cd "${srcdir}/youki"

  cargo test --frozen --release
}

package() {
  cd "${srcdir}/youki"

  install -vDm755 -t "$pkgdir/usr/bin" target/release/
  install -vDm0644 "LICENSE" "${pkgdir}/usr/share/licenses/youki/LICENSE"

  # shell completions
  install -vDm644 "target/bash-completion" "$pkgdir/usr/share/bash-completion/completions/youki"
  install -vDm644 "target/fish-completion" "$pkgdir/usr/share/fish/vendor_completions.d/youki.fish"
  install -vDm644 "target/zsh-completion" "$pkgdir/usr/share/zsh/site-functions/_youki"
}
