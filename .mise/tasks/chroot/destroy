#!/usr/bin/env bash
#MISE description="Destroys chroot environment"

[[ -n "${CHROOT_DIR:-}" ]] || { echo "error: CHROOT_DIR not set" >&2; exit 1; }

case "$CHROOT_DIR" in
  "/" | "" | ".")
    echo "error: refusing to delete CHROOT_DIR=$CHROOT_DIR" >&2
    exit 1
    ;;
esac

run0 rm -rf "$CHROOT_DIR"