#!/usr/bin/env bash
#MISE description="Check required tools are installed"

set -euo pipefail

need_bins=(
  bash
  git
  makepkg
  repo-add
  mkarchroot
  makechrootpkg
)

missing=0
for bin in "${need_bins[@]}"; do
  if ! command -v "$bin" >/dev/null 2>&1; then
    echo "Missing: $bin"
    missing=1
  fi
done

# aur (aurutils) is managed as a local package — check separately with a hint
if ! command -v aur >/dev/null 2>&1; then
  echo "Missing: aur (aurutils)"
  echo "  aurutils is a local package. Build and install it first:"
  echo "    cd pkgs/aurutils && mise run package:build"
  echo "    sudo pacman -U <built .pkg.tar.zst>"
  missing=1
fi

if [ "$missing" -ne 0 ]; then
  exit 1
fi

echo "OK"
