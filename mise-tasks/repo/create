#!/usr/bin/env bash
#MISE description="Provisions system repo directory under /srv for PKGDEST"
#MISE depends=["run0"]
#USAGE flag "--dir <dir>"   help="Repo directory path (e.g., /srv/repo)" env="REPO_DIR"
#USAGE flag "--db <file>"   help="Path to repo DB file (e.g., /srv/repo/repo.db.tar.gz)" env="REPO_DB"
#USAGE flag "--group <grp>" help="Group for repo dir (default: REPO_NAME)" env="REPO_GROUP"
#USAGE flag "--name <name>" help="Fallback group name if REPO_GROUP unset" env="REPO_NAME"
#USAGE flag "--user <user>" help="User to add to repo group (default: $USER)" env="REPO_USER"

set -euo pipefail

# Read from usage-provided args first, then fall back to env vars
REPO_DIR="${usage_dir:-${REPO_DIR:-}}"
REPO_DB="${usage_db:-${REPO_DB:-}}"

# Name can come from --name or env
REPO_NAME="${usage_name:-${REPO_NAME:-}}"

# Group selection: allow override, else fall back to REPO_NAME
REPO_GROUP="${usage_group:-${REPO_GROUP:-${REPO_NAME:-}}}"

# User to add: allow override, else fall back to env, else $USER
REPO_USER="${usage_user:-${REPO_USER:-${USER:-}}}"

[[ -n "${REPO_DIR}" ]] || { echo "error: REPO_DIR is required (or use --dir)" >&2; exit 1; }
[[ -n "${REPO_DB}" ]] || { echo "error: REPO_DB is required (or use --db)" >&2; exit 1; }
[[ -n "${REPO_GROUP}" ]] || { echo "error: REPO_GROUP or REPO_NAME must be set" >&2; exit 1; }
[[ -n "${REPO_USER}" ]] || { echo "error: REPO_USER is empty and \$USER is empty" >&2; exit 1; }

case "${REPO_DIR}" in
  "/" | ".")
    echo "error: Refusing to use REPO_DIR=${REPO_DIR}" >&2
    exit 1
    ;;
esac

group_exists() {
  getent group "$1" >/dev/null 2>&1
}

ensure_group_exists() {
  local group="$1"

  group_exists "$group" && return 0

  echo "Creating group: $group"
  if run0 groupadd "$group"; then
    return 0
  fi

  if group_exists "$group"; then
    echo "Group '$group' already exists (detected after groupadd); continuing."
    return 0
  fi

  echo "error: Failed to create group '$group'." >&2
  echo "error: Try: run0 groupadd '$group'" >&2
  exit 1
}

is_homed_user() {
  command -v homectl >/dev/null 2>&1 || return 1
  homectl inspect "$1" >/dev/null 2>&1
}

homed_aux_groups() {
  local user="$1"

  homectl inspect "$user" | awk '
    BEGIN { in_section=0; saw=0 }
    /^[[:space:]]*Aux\.[[:space:]]Groups:/ {
      in_section=1; saw=1
      sub(/^[[:space:]]*Aux\.[[:space:]]Groups:[[:space:]]*/, "", $0)
      if (length($0)) print $0
      next
    }
    in_section==1 && /^[[:space:]]*[A-Z][A-Za-z[:space:]]*:/ { in_section=0 }
    in_section==1 {
      gsub(/^[[:space:]]+/, "", $0)
      if (length($0)) print $0
    }
    END { if (saw==0) exit 3 }
  ' | sed '/^$/d' | sort -u
}

list_contains() { grep -qxF "$1"; }

member_of_from_aux_plus() {
  local group="$1"
  { cat; printf '%s\n' "$group"; } \
    | sed '/^$/d' \
    | sort -u \
    | paste -sd, -
}

add_user_non_homed() {
  local user="$1"
  local group="$2"

  echo "Adding '$user' to group '$group' using usermod..."
  run0 usermod -aG "$group" "$user"
}

add_user_homed() {
  local user="$1"
  local group="$2"

  command -v homectl >/dev/null 2>&1 || {
    echo "error: homectl is required for systemd-homed users but was not found." >&2
    exit 127
  }

  local aux
  if ! aux="$(homed_aux_groups "$user")"; then
    echo "error: Failed to parse Aux. Groups for homed user '$user'." >&2
    echo "error: Run: homectl inspect \"$user\"" >&2
    exit 1
  fi

  if printf '%s\n' "$aux" | list_contains "$group"; then
    echo "Homed user '$user' already in '$group'; nothing to do."
    return 0
  fi

  local member_of
  member_of="$(printf '%s\n' "$aux" | member_of_from_aux_plus "$group")"

  echo "Adding homed user '$user' to '$group' via homectl..."
  set +e
  run0 homectl update "$user" --member-of="$member_of"
  local rc=$?
  set -e

  aux="$(homed_aux_groups "$user" || true)"
  if printf '%s\n' "$aux" | list_contains "$group"; then
    [[ $rc -ne 0 ]] && echo "homectl returned rc=$rc but membership is present."
    echo "OK. '$user' is now in '$group' (systemd-homed)."
    echo "Note: some sessions may require re-login."
    return 0
  fi

  echo "error: Failed to add '$user' to '$group'." >&2
  exit 1
}

assert_repo_writable_or_explain() {
  local dir="$1"
  local user="$2"
  local group="$3"

  [[ -w "$dir" ]] && return 0

  echo "error: Repo dir exists but is not writable: $dir" >&2
  if [[ -n "$user" ]] && is_homed_user "$user"; then
    echo "error: Ensure '$user' is in '$group':" >&2
    echo "error:   homectl inspect \"$user\" | sed -n '/Aux\\. Groups:/,/^[A-Z]/p'" >&2
  else
    echo "error: Join '$group' and re-login (or run: newgrp $group)." >&2
  fi
  exit 1
}

echo "Provisioning repo dir: $REPO_DIR"
echo "Using repo group: $REPO_GROUP"
echo "Ensuring user in group: $REPO_USER"

ensure_group_exists "$REPO_GROUP"

if is_homed_user "$REPO_USER"; then
  add_user_homed "$REPO_USER" "$REPO_GROUP"
else
  add_user_non_homed "$REPO_USER" "$REPO_GROUP"
fi

# Privileged filesystem provisioning (single run0 session)
run0 bash -lc '
set -euo pipefail

dir="$1"
group="$2"
db="$3"

install -d -m 2775 -o root -g "$group" "$dir"
chown root:"$group" "$dir"
chmod 2775 "$dir"
find "$dir" -type d -exec chmod g+s {} +

db_dir="$(dirname "$db")"
install -d -m 2775 -o root -g "$group" "$db_dir"
chown root:"$group" "$db_dir"
chmod 2775 "$db_dir"

if [[ ! -f "$db" ]]; then
  touch "$db"
  chown root:"$group" "$db"
  chmod 664 "$db"
fi
' -- "$REPO_DIR" "$REPO_GROUP" "$REPO_DB"

assert_repo_writable_or_explain "$REPO_DIR" "$REPO_USER" "$REPO_GROUP"

echo "OK"
