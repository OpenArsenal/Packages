pkgname=aube
pkgver=1.15.0
pkgrel=1
pkgdesc='Fast Node.js package manager with lifecycle-script jailing'
arch=('x86_64' 'aarch64')
url='https://aube.en.dev'
license=('MIT')
# Release+LTO currently breaks the `aube-resolver` build script at link time
# with unresolved `ZSTD_*` symbols under the packaging toolchain.
options=('!lto')
install='aube.install'
depends=('gcc-libs' 'nodejs')
# `aube-resolver` generates an embedded primer at build time via `node`, and
# the packaged CLI is expected to work as a system-wide Node package manager.
makedepends=('cargo' 'cmake' 'usage')
checkdepends=('cargo')
optdepends=(
  'mise: manage Node.js runtimes alongside aube'
  'usage: regenerate shell completions and manpages from aube usage'
)
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/endevco/aube/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('1dd9a4028ec5fc67f131d8c4f7174bb8a12df7e861fcd16e7690fc7c18fffe78')

prepare() {
  cd "${pkgname}-${pkgver}"

  export RUSTUP_TOOLCHAIN=stable
  # Keep Cargo's cache inside $srcdir so later phases can stay offline.
  export CARGO_HOME="${srcdir}/cargo-home"
  export CARGO_TARGET_DIR=target

  cargo fetch --locked --target "${CARCH}-unknown-linux-gnu"
}

build() {
  cd "${pkgname}-${pkgver}"

  export RUSTUP_TOOLCHAIN=stable
  export CARGO_HOME="${srcdir}/cargo-home"
  export CARGO_TARGET_DIR=target
  # Arch warns on leaked $srcdir references; Rust and native deps each need
  # their own path remapping.
  export RUSTFLAGS="${RUSTFLAGS:+${RUSTFLAGS} }--remap-path-prefix=${srcdir}/${pkgname}-${pkgver}=. --remap-path-prefix=${srcdir}/cargo-home=./cargo-home --remap-path-prefix=${srcdir}=."
  export CFLAGS="${CFLAGS:+${CFLAGS} }-ffile-prefix-map=${srcdir}=."
  export CXXFLAGS="${CXXFLAGS:+${CXXFLAGS} }-ffile-prefix-map=${srcdir}=."

  cargo build --release --frozen --manifest-path crates/aube/Cargo.toml --bin aube --bin aubr --bin aubx
}

check() {
  cd "${pkgname}-${pkgver}"

  export RUSTUP_TOOLCHAIN=stable
  export CARGO_HOME="${srcdir}/cargo-home"
  export CARGO_TARGET_DIR=target
  export RUSTFLAGS="${RUSTFLAGS:+${RUSTFLAGS} }--remap-path-prefix=${srcdir}/${pkgname}-${pkgver}=. --remap-path-prefix=${srcdir}/cargo-home=./cargo-home --remap-path-prefix=${srcdir}=."
  export CFLAGS="${CFLAGS:+${CFLAGS} }-ffile-prefix-map=${srcdir}=."
  export CXXFLAGS="${CXXFLAGS:+${CXXFLAGS} }-ffile-prefix-map=${srcdir}=."

  cargo test --frozen --manifest-path crates/aube/Cargo.toml --test e2e
}

package() {
  cd "${pkgname}-${pkgver}"

  install -Dm755 target/release/aube "${pkgdir}/usr/bin/aube"
  # Upstream dispatches `aubr`/`aubx` by argv[0], so symlinks are sufficient.
  ln -s aube "${pkgdir}/usr/bin/aubr"
  ln -s aube "${pkgdir}/usr/bin/aubx"

  target/release/aube usage > aube.usage.kdl

  usage generate completion bash aube --file aube.usage.kdl > aube.bash
  usage generate completion bash aubr --file aube.usage.kdl > aubr.bash
  usage generate completion bash aubx --file aube.usage.kdl > aubx.bash

  usage generate completion fish aube --file aube.usage.kdl > aube.fish
  usage generate completion fish aubr --file aube.usage.kdl > aubr.fish
  usage generate completion fish aubx --file aube.usage.kdl > aubx.fish

  usage generate completion zsh aube --file aube.usage.kdl > _aube
  usage generate completion zsh aubr --file aube.usage.kdl > _aubr
  usage generate completion zsh aubx --file aube.usage.kdl > _aubx

  usage generate manpage --file aube.usage.kdl > aube.1

  install -Dm644 aube.bash "${pkgdir}/usr/share/bash-completion/completions/aube"
  install -Dm644 aubr.bash "${pkgdir}/usr/share/bash-completion/completions/aubr"
  install -Dm644 aubx.bash "${pkgdir}/usr/share/bash-completion/completions/aubx"
  install -Dm644 aube.fish "${pkgdir}/usr/share/fish/vendor_completions.d/aube.fish"
  install -Dm644 aubr.fish "${pkgdir}/usr/share/fish/vendor_completions.d/aubr.fish"
  install -Dm644 aubx.fish "${pkgdir}/usr/share/fish/vendor_completions.d/aubx.fish"
  install -Dm644 _aube "${pkgdir}/usr/share/zsh/site-functions/_aube"
  install -Dm644 _aubr "${pkgdir}/usr/share/zsh/site-functions/_aubr"
  install -Dm644 _aubx "${pkgdir}/usr/share/zsh/site-functions/_aubx"
  install -Dm644 aube.1 "${pkgdir}/usr/share/man/man1/aube.1"

  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
