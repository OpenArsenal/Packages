pkgname=aube
pkgver=1.14.1
pkgrel=1
pkgdesc='Fast Node.js package manager with lifecycle-script jailing'
arch=('x86_64' 'aarch64')
url='https://aube.en.dev'
license=('MIT')
# Release+LTO currently breaks the `aube-resolver` build script at link time
# with unresolved `ZSTD_*` symbols under the packaging toolchain.
options=('!lto')
install='aube.install'
depends=('gcc-libs')
# `aube-resolver` generates an embedded primer at build time via `node`.
makedepends=('cargo' 'cmake' 'nodejs')
checkdepends=('cargo')
optdepends=(
  'nodejs: run package scripts using a system Node.js runtime'
  'mise: manage Node.js runtimes alongside aube'
  'usage: generate shell completions with aube completion'
)
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/endevco/aube/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('ce4907b971da672cf1de6d71673a6b6c4a84ec8cfdeec2f6e31f463b367e56f1')

prepare() {
  cd "${pkgname}-${pkgver}"

  export RUSTUP_TOOLCHAIN=stable
  # Keep Cargo's cache inside $srcdir so later phases can stay offline.
  export CARGO_HOME="${srcdir}/cargo-home"
  export CARGO_TARGET_DIR=target

  cargo fetch --locked --target "${CARCH}-unknown-linux-gnu"
}

build() {
  cd "${pkgname}-${pkgver}"

  export RUSTUP_TOOLCHAIN=stable
  export CARGO_HOME="${srcdir}/cargo-home"
  export CARGO_TARGET_DIR=target
  # Arch warns on leaked $srcdir references; Rust and native deps each need
  # their own path remapping.
  export RUSTFLAGS="${RUSTFLAGS:+${RUSTFLAGS} }--remap-path-prefix=${srcdir}/${pkgname}-${pkgver}=. --remap-path-prefix=${srcdir}/cargo-home=./cargo-home --remap-path-prefix=${srcdir}=."
  export CFLAGS="${CFLAGS:+${CFLAGS} }-ffile-prefix-map=${srcdir}=."
  export CXXFLAGS="${CXXFLAGS:+${CXXFLAGS} }-ffile-prefix-map=${srcdir}=."

  cargo build --release --frozen --manifest-path crates/aube/Cargo.toml --bin aube --bin aubr --bin aubx
}

check() {
  cd "${pkgname}-${pkgver}"

  export RUSTUP_TOOLCHAIN=stable
  export CARGO_HOME="${srcdir}/cargo-home"
  export CARGO_TARGET_DIR=target
  export RUSTFLAGS="${RUSTFLAGS:+${RUSTFLAGS} }--remap-path-prefix=${srcdir}/${pkgname}-${pkgver}=. --remap-path-prefix=${srcdir}/cargo-home=./cargo-home --remap-path-prefix=${srcdir}=."
  export CFLAGS="${CFLAGS:+${CFLAGS} }-ffile-prefix-map=${srcdir}=."
  export CXXFLAGS="${CXXFLAGS:+${CXXFLAGS} }-ffile-prefix-map=${srcdir}=."

  cargo test --frozen --manifest-path crates/aube/Cargo.toml --test e2e
}

package() {
  cd "${pkgname}-${pkgver}"

  install -Dm755 target/release/aube "${pkgdir}/usr/bin/aube"
  # Upstream dispatches `aubr`/`aubx` by argv[0], so symlinks are sufficient.
  ln -s aube "${pkgdir}/usr/bin/aubr"
  ln -s aube "${pkgdir}/usr/bin/aubx"

  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
