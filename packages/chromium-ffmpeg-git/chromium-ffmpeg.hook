[Trigger]
Operation=Install
Operation=Upgrade
Type=Package
Target=chromium-ffmpeg
Target=nwjs
Target=nwjs-bin
Target=vivaldi
Target=vivaldi-snapshot
Target=opera
Target=opera-beta
Target=opera-developer

[Action]
When=PostTransaction
Exec=/usr/bin/bash -c 'chmod a-r /usr/lib/opera-{stable,beta,developer}/libffmpeg.so /opt/{vivaldi,vivaldi-snapshot,nwjs}/lib/libffmpeg.so 2>/dev/null||:'
