# Maintainer: Okiki <okiki@thunderstrike.co>
_nodeversion=22
_electronversion=39

pkgname=affine-electron-git
_pkgname=AFFiNE
_upstream_name=AFFiNE
pkgver=0.26.6.r11237.gdb0ff0a9df
pkgrel=1
pkgdesc="Collaborative knowledge base and whiteboard desktop application (git version; system Electron)"
arch=('x86_64')
url="https://affine.pro/"
_ghurl="https://github.com/toeverything/AFFiNE"
_branch='canary'
license=('LicenseRef-custom' 'MIT')
options=('debug' 'strip')
install='affine.install'

_arch=x64
_pkgsrc="${pkgname}"
_app_version="${pkgver%%.r*}"

provides=("affine=${pkgver}")
conflicts=('affine')

depends=(
  "electron${_electronversion}"
  'bash'
)

makedepends=(
  'nodejs-lts-jod'
  'corepack'
  'yarn'
  'asar'
  'python'
  'zip'
  'unzip'
  'cargo'
  'cmake'
  'git'
  'jq'
)

source=(
  "${_pkgsrc}::git+${_ghurl}.git#branch=${_branch}"
  'affine.desktop'
  'affine-flags-wrapper.sh'
)

sha256sums=('SKIP'
            '8ee4d9ae3d73c67e88d0813203240c9b6b381603f9beb3f04641aeff965b801c'
            '655f857035aeed0883ae28622256af2a3b06764b684d22f7607c41e83325fb5d')

pkgver() {
  cd "${srcdir}/${_pkgsrc}"

  local _latest_tag _rev_count _commit
  _latest_tag="$(git tag --sort=-v:refname | grep -E '^v?[0-9]+\.[0-9]+\.[0-9]+$' | head -n1)"
  _latest_tag="${_latest_tag#v}"
  _rev_count="$(git rev-list --count HEAD)"
  _commit="$(git rev-parse --short HEAD)"

  printf '%s.r%s.g%s\n' "${_latest_tag:-0.0.0}" "${_rev_count}" "${_commit}"
}

_setup_build_toolchain() {
  local package_manager

  local node_major="$(node --version)"
  node_major="${node_major#v}"
  node_major="${node_major%%.*}"

  if [[ "${node_major}" != "${_nodeversion}" ]]; then
    echo "Node.js major version ${node_major} does not match upstream requirement ${_nodeversion}"
    exit 1
  fi

  package_manager="$(jq -r '.packageManager' package.json)"
  if [[ ! "${package_manager}" =~ ^yarn@ ]]; then
    echo "Unsupported package manager ${package_manager}"
    exit 1
  fi

  corepack prepare "${package_manager}" --activate >/dev/null
}

_disable_workspace_postinstalls() {
  local _manifest
  local _manifests=(
    'package.json'
    'packages/backend/server/package.json'
    'packages/frontend/templates/package.json'
  )

  for _manifest in "${_manifests[@]}"; do
    [[ -f "${_manifest}" ]] || continue
    jq 'if (.scripts.postinstall? != null) then .scripts.postinstall = ":" else . end' \
      "${_manifest}" > "${_manifest}.tmp"
    mv "${_manifest}.tmp" "${_manifest}"
  done
}

_assert_generated_workspace_state() {
  local _required_files=(
    'tools/utils/src/workspace.gen.ts'
    '.oxlintrc.json'
  )
  local _required

  for _required in "${_required_files[@]}"; do
    if [[ ! -f "${_required}" ]]; then
      printf 'Missing generated workspace file: %s\n' "${_required}" >&2
      exit 1
    fi
  done
}

_patch_build_label_fallback() {
  local _html_plugin='tools/cli/src/webpack/html-plugin.ts'

  [[ -f "${_html_plugin}" ]] || return 0

  # AFFiNE only forwards this value into emitted HTML and assets-manifest.json,
  # so use an explicit Arch build label instead of implying it is a raw Git SHA.
  perl -0pi -e 's@const \{ GITHUB_SHA \} = process\.env;@const { AFFINE_BUILD_LABEL, GITHUB_SHA } = process.env;\n  if (AFFINE_BUILD_LABEL) {\n    return AFFINE_BUILD_LABEL;\n  }@' "${_html_plugin}"

  if ! grep -Fq 'AFFINE_BUILD_LABEL' "${_html_plugin}"; then
    printf 'Failed to patch %s for build-label fallback.\n' "${_html_plugin}" >&2
    exit 1
  fi
}

_prepare_system_electron_runtime() {
  local _electron_module='node_modules/electron'
  local _electron_root="/usr/lib/electron${_electronversion}"

  if [[ ! -d "${_electron_module}" ]]; then
    printf 'Missing npm electron package under %s\n' "${_electron_module}" >&2
    exit 1
  fi

  if [[ ! -x "${_electron_root}/electron" ]]; then
    printf 'Missing system Electron runtime under %s\n' "${_electron_root}" >&2
    exit 1
  fi

  rm -rf "${_electron_module}/dist"
  ln -s "${_electron_root}" "${_electron_module}/dist"
  printf '%s\n' 'electron' > "${_electron_module}/path.txt"
}

_common_build_env() {
  export HUSKY=0
  export PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
  export SENTRYCLI_SKIP_DOWNLOAD=1
  export AFFINE_BUILD_LABEL="${pkgver}"
  export COREPACK_HOME="${SRCDEST:-${srcdir}}/${pkgname}-corepack"
}

_scrub_srcdir_references() {
  local _root="$1"

  [[ -d "${_root}" ]] || return 0

  grep -IlRZ -F "${srcdir}" "${_root}" 2>/dev/null |
    xargs -0 -r sed -i "s#${srcdir}#/usr/src/debug/${pkgname}#g"
}

_unpack_asar_payload() {
  local _asar="$1"
  local _app_dir="${_asar%.asar}"

  [[ -f "${_asar}" ]] || return 0

  rm -rf "${_app_dir}"
  asar extract "${_asar}" "${_app_dir}"
  rm -f "${_asar}"

  find "${_app_dir}" -type f -name '*.map' -delete 2>/dev/null || true
  _scrub_srcdir_references "${_app_dir}"
}

_assert_no_srcdir_references() {
  local _hits=()

  mapfile -d '' _hits < <(LC_ALL=C grep -aRZlF "${srcdir}" "${pkgdir}" 2>/dev/null || true)
  if ((${#_hits[@]})); then
    printf '%s\n' 'ERROR: package still contains references to $srcdir:'
    printf '  %s\n' "${_hits[@]#${pkgdir}/}"
    return 1
  fi
}

_remove_updater_metadata() {
  local _root="$1"

  [[ -d "${_root}" ]] || return 0

  # Pacman-managed builds must not point electron-updater at upstream release
  # feeds. Keep AFFiNE's internal updater configuration harmless by removing
  # updater metadata generated by electron-builder/electron-updater.
  find "${_root}" -type f \( \
    -name 'app-update.yml' -o \
    -name 'dev-app-update.yml' -o \
    -name 'latest*.yml' \
  \) -delete 2>/dev/null || true
}

_affine_prepare() {
  cd "${srcdir}/${_pkgsrc}"
  _common_build_env
  _patch_build_label_fallback
  _assert_generated_workspace_state
  _disable_workspace_postinstalls
  _setup_build_toolchain

  local electron_pkg_major
  electron_pkg_major="$(jq -r .devDependencies.electron package.json | tr -d '^' | cut -d. -f1)"
  if [[ "${_electronversion}" -ne "${electron_pkg_major}" ]]; then
    echo "Electron version ${_electronversion} does not match ${electron_pkg_major} in package.json"
    exit 1
  fi

  yarn install --immutable --inline-builds
}

_affine_build() {
  cd "${srcdir}/${_pkgsrc}"
  _common_build_env
  _setup_build_toolchain

  export APP_VERSION="${_app_version}"
  ./scripts/set-version.sh "${APP_VERSION}"

  CFLAGS+=' -ffat-lto-objects'
  yarn affine @affine/native build

  export BUILD_TYPE=stable
  export RELEASE_VERSION="${_app_version}"

  SKIP_NX_CACHE=1 yarn affine @affine/electron generate-assets
  yarn config set nmMode classic
  yarn config set nmHoistingLimits workspaces
  find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +
  yarn workspaces focus @affine/electron @affine/monorepo @affine/nbstore @toeverything/infra

  _prepare_system_electron_runtime
  SKIP_WEB_BUILD=1 SKIP_BUNDLE=1 HOIST_NODE_MODULES=1 NODE_OPTIONS='--max-old-space-size=14384' DEBUG='affine:*,napi:*' yarn affine @affine/electron make --platform=linux --arch="${_arch}"
  unzip -o packages/frontend/apps/electron/out/stable/make/zip/linux/${_arch}/${_upstream_name}-linux-${_arch}-${_app_version}.zip
}

prepare() {
  _app_version="${pkgver%%.r*}"
  export ELECTRON_SKIP_BINARY_DOWNLOAD=1
  export ELECTRON_OVERRIDE_DIST_PATH="/usr/lib/electron${_electronversion}"
  _affine_prepare
}

build() {
  _app_version="${pkgver%%.r*}"
  export ELECTRON_SKIP_BINARY_DOWNLOAD=1
  export ELECTRON_OVERRIDE_DIST_PATH="/usr/lib/electron${_electronversion}"
  _affine_build
}

_package_system_electron_affine() {
  local _bundle="${srcdir}/${_pkgsrc}/${_upstream_name}-linux-${_arch}"
  local _install_root="${pkgdir}/usr/lib/affine"
  local _resources="${_bundle}/resources"
  local _electron_version_full

  _electron_version_full="$(<"/usr/lib/electron${_electronversion}/version")"

  install -d "${_install_root}"
  cp -a "${_resources}/." "${_install_root}/"

  _remove_updater_metadata "${_install_root}"

  if [[ ! -f "${_install_root}/app.asar" && ! -d "${_install_root}/app" ]]; then
    printf '%s\n' "ERROR: could not locate AFFiNE Electron app payload."
    printf 'Checked:\n  %s\n  %s\n' \
      "${_install_root}/app.asar" \
      "${_install_root}/app"
    return 1
  fi

  _unpack_asar_payload "${_install_root}/app.asar"
  find "${_install_root}" -type f -name '*.map' -delete 2>/dev/null || true
  _scrub_srcdir_references "${_install_root}"

  install -Dm644 "${srcdir}/${_pkgsrc}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 "${srcdir}/${_pkgsrc}/LICENSE-MIT" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-MIT"
  install -Dm644 "${srcdir}/${_pkgsrc}/packages/frontend/apps/electron/resources/icons/icon_stable_64x64.png" "${pkgdir}/usr/share/icons/hicolor/64x64/apps/affine.png"
  install -Dm644 "${srcdir}/${_pkgsrc}/packages/frontend/apps/electron/resources/icons/icon_stable_64x64.png" "${pkgdir}/usr/share/pixmaps/affine.png"
  install -Dm644 "${srcdir}/affine.desktop" "${pkgdir}/usr/share/applications/affine.desktop"

  local _app_path="/usr/lib/affine/app.asar"
  [[ -d "${_install_root}/app" ]] && _app_path="/usr/lib/affine/app"

  sed \
    -e "s#@ELECTRON_CMD@#/usr/bin/electron${_electronversion}#g" \
    -e "s#@AFFINE_APP@#${_app_path}#g" \
    "${srcdir}/affine-flags-wrapper.sh" >"${srcdir}/affine"

  if grep -q '@[A-Z_][A-Z_]*@' "${srcdir}/affine"; then
    printf '%s\n' "ERROR: unresolved wrapper placeholder(s):"
    grep -n '@[A-Z_][A-Z_]*@' "${srcdir}/affine"
    return 1
  fi

  install -Dm755 "${srcdir}/affine" "${pkgdir}/usr/bin/affine"
  install -Dm644 /dev/stdin "${_install_root}/electron_version" <<<"${_electron_version_full}"

  _assert_no_srcdir_references

}

package() {
  _package_system_electron_affine
}
