_approve_pnpm_builds() {
  python - <<'PYTHON_EOF'
from pathlib import Path

path = Path("pnpm-workspace.yaml")
if path.exists():
    lines = path.read_text().splitlines()
else:
    lines = []

if any(line.strip() == "- arrpc" for line in lines):
    raise SystemExit

for index, line in enumerate(lines):
    if line.strip() == "onlyBuiltDependencies:":
        indent = line[:len(line) - len(line.lstrip())]
        lines.insert(index + 1, f"{indent}  - arrpc")
        break
else:
    if lines and lines[-1].strip():
        lines.append("")
    lines.extend([
        "onlyBuiltDependencies:",
        "  - arrpc",
    ])

path.write_text("\n".join(lines) + "\n")
PYTHON_EOF
}

_nvm_env() {
  local _cache_root="${SRCDEST:-${srcdir}}"

  export HOME="${_cache_root}/${pkgname}-node-home"
  export XDG_CACHE_HOME="${HOME}/.cache"
  export XDG_CONFIG_HOME="${HOME}/.config"
  export XDG_DATA_HOME="${HOME}/.local/share"

  export NVM_DIR="${_cache_root}/${pkgname}-node-nvm"

  source /usr/share/nvm/init-nvm.sh || [[ $? != 1 ]]
  nvm install "${_nodeversion}"
  nvm use "${_nodeversion}"
}

build() {
  _nvm_env

  cd "${srcdir}/${_pkgsrc}"

  _approve_pnpm_builds
  pnpm install --frozen-lockfile
  pnpm updateArrpcDB
  pnpm build
  pnpm exec electron-builder --dir
}

package() {
  local _bundle="${srcdir}/${_pkgsrc}/dist/linux-unpacked"
  local _install_root="${pkgdir}/opt/vesktop"
  local _app_exec="/opt/vesktop/vesktop"
  local _electron_version=""
  local _file

  if [[ ! -d "${_bundle}" ]]; then
    _bundle="$(find "${srcdir}/${_pkgsrc}/dist" -maxdepth 1 -type d -name 'linux-*unpacked' -print -quit)"
  fi

  [[ -n "${_bundle}" && -d "${_bundle}" ]] || {
    printf '%s\n' "ERROR: could not locate Vesktop Electron bundle."
    return 1
  }

  install -d "${_install_root}"
  cp -a "${_bundle}/." "${_install_root}/"

  install -Dm644 "${srcdir}/${_pkgsrc}/build/icon.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/vesktop.svg"
  install -Dm644 "${srcdir}/vesktop.desktop" "${pkgdir}/usr/share/applications/vesktop.desktop"
  install -Dm644 "${srcdir}/${_pkgsrc}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  if [[ -x "${_install_root}/Vesktop" ]]; then
    _app_exec="/opt/vesktop/Vesktop"
  fi

  sed -e "s#@VESKTOP_EXEC@#${_app_exec}#g" "${srcdir}/vesktop-flags-wrapper.sh" >"${srcdir}/vesktop"

  if grep -q '@[A-Z_][A-Z_]*@' "${srcdir}/vesktop"; then
    printf '%s\n' "ERROR: unresolved wrapper placeholder(s):"
    grep -n '@[A-Z_][A-Z_]*@' "${srcdir}/vesktop"
    return 1
  fi

  install -Dm755 "${srcdir}/vesktop" "${pkgdir}/usr/bin/vesktop"

  for _file in "${_install_root}/vesktop" "${_install_root}/Vesktop"; do
    if [[ -x "${_file}" ]]; then
      _electron_version="$(strings "${_file}" | grep -Pom1 'Electron/[0-9.]+' || true)"
      [[ -n "${_electron_version}" ]] && break
    fi
  done

  _electron_version="${_electron_version#Electron/}"
  if [[ -n "${_electron_version}" ]]; then
    install -Dm644 /dev/stdin "${_install_root}/electron_version" <<<"${_electron_version}"
  fi

  chmod -R u=rwX,go=rX "${pkgdir}"
}
