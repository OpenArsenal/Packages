_nodeversion=22

pkgname=vesktop
pkgver=1.6.5
pkgrel=1
pkgdesc="A standalone Electron-based Discord app with Vencord & improved Linux support (bundled Electron)"
arch=('x86_64' 'aarch64')
url="https://github.com/Vencord/Vesktop"
license=('GPL-3.0-only')
options=('!debug' '!strip')

_pkgsrc="Vesktop-${pkgver}"

conflicts=(
  'vesktop-git'
  'vesktop-bin'
  'vesktop-electron'
  'vesktop-electron-git'
)
install='vesktop.install'

depends=(
  'alsa-lib'
  'at-spi2-core'
  'bash'
  'cairo'
  'dbus'
  'expat'
  'glib2'
  'gtk3'
  'libcups'
  'libx11'
  'libxcb'
  'libxcomposite'
  'libxdamage'
  'libxext'
  'libxfixes'
  'libxkbcommon'
  'libxrandr'
  'mesa'
  'nspr'
  'nss'
  'pango'
  'systemd-libs'
  'zlib'
)

makedepends=(
  'nvm'
  'pnpm'
)

source=(
  "${_pkgsrc}.tar.gz::${url}/archive/v${pkgver}.tar.gz"
  'vesktop.desktop'
  'vesktop-flags-wrapper.sh'
)

sha256sums=('4bb9b5e1acaf17a5f145931008fe4015f9b8c1116b769e1a55a68d5483f238fc'
