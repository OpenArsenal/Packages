# Maintainer: Okiki <okiki@thunderstrike.co>
pkgname=affine
_pkgname=AFFiNE
pkgver='0.26.3'
_electronversion=39
pkgrel=1
pkgdesc="Collaborative knowledge base and whiteboard desktop application"
arch=('x86_64')
url="https://affine.pro/"
_ghurl="https://github.com/toeverything/AFFiNE"
license=(
    'LicenseRef-custom'
    'MIT'
)
conflicts=('affine-bin')
depends=(
    "electron${_electronversion}"
)
makedepends=(
    # Affine pins Node 22 in .nvmrc and targets node22 in the Electron build.
    nodejs-lts-jod
    corepack
    yarn
    # node gyp
    python
    # electron-packager
    zip unzip
    # Rust
    cargo
    # Misc
    git jq
)
source=(
    "${_pkgname}::git+https://github.com/toeverything/AFFiNE#tag=v${pkgver}"
    "${pkgname}.sh"
    "${pkgname}.desktop"
)
sha256sums=('d2e42f1cd58f4e0656f506fcc47398dcb16c902d49c45e49552ffd3662dda708'
            'd871984a01d47c5c70f6f5d0ae3f6e2fbe1ae2da4c95306a2901f59d19d395ae'
            '454beba85b0c1996aaa28e633da8eb96bb2c7f9cc699fa31d3adde1b64e7ebca')

_arch=x64

_setup_build_toolchain() {
    local package_manager

    local node_major="$(node --version)" # node --version outputs a v prefix, e.g. v22.22.2
    node_major="${node_major#v}" # remove the v prefix, e.g. 22.22.2
    node_major="${node_major%%.*}" # extract the major version number, e.g. 22 from 22.22.2

    if [[ "${node_major}" != "22" ]]; then
        echo "Node.js major version ${node_major} does not match upstream requirement 22"
        exit 1
    fi

    package_manager="$(jq -r '.packageManager' package.json)"
    if [[ ! "${package_manager}" =~ ^yarn@ ]]; then
        echo "Unsupported package manager ${package_manager}"
        exit 1
    fi

    corepack prepare "${package_manager}" --activate >/dev/null
}

prepare() {
    local electron_pkg_ver

    cd "$_pkgname"
    export HUSKY=0
    export PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
    export ELECTRON_SKIP_BINARY_DOWNLOAD=1
    export SENTRYCLI_SKIP_DOWNLOAD=1
    _setup_build_toolchain
    electron_pkg_ver="$(jq -r .devDependencies.electron package.json | tr -d '^' | cut -d. -f1)" # Extract major version number from ^39.0.0 -> 39
    if [[ "$_electronversion" -ne "${electron_pkg_ver}" ]]; then
        echo "Electron version ${_electronversion} does not match ${electron_pkg_ver} in package.json"
	exit 1
    fi
    yarn install --immutable --inline-builds
}

build() {
    # https://github.com/toeverything/AFFiNE/blob/canary/docs/building-desktop-client-app.md
    cd "$_pkgname"
    export HUSKY=0
    export PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
    export ELECTRON_SKIP_BINARY_DOWNLOAD=1
    export SENTRYCLI_SKIP_DOWNLOAD=1
    _setup_build_toolchain
    # https://github.com/toeverything/AFFiNE/blob/v0.18.2/.github/actions/setup-version/action.yml
    export APP_VERSION="${pkgver}"
    ./scripts/set-version.sh "${APP_VERSION}"
    CFLAGS+=' -ffat-lto-objects' # https://github.com/launchbadge/sqlx/issues/3149
    yarn affine @affine/native build
    export BUILD_TYPE=stable
    export RELEASE_VERSION="${pkgver}"
    SKIP_NX_CACHE=1 yarn affine @affine/electron generate-assets
    yarn config set nmMode classic
    yarn config set nmHoistingLimits workspaces
    find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +
    yarn workspaces focus @affine/electron @affine/monorepo @affine/nbstore @toeverything/infra
    node ./node_modules/electron/install.js
    SKIP_WEB_BUILD=1 SKIP_BUNDLE=1 HOIST_NODE_MODULES=1 NODE_OPTIONS='--max-old-space-size=14384' DEBUG='affine:*,napi:*' yarn affine @affine/electron make --platform=linux --arch="${_arch}"
    unzip packages/frontend/apps/electron/out/stable/make/zip/linux/${_arch}/${_pkgname}-linux-${_arch}-${pkgver}.zip
}

package() {
    sed -e "
        s/@electronversion@/${_electronversion}/g
        s/@appname@/${pkgname}/g
        s/@runname@/app.asar/g
        s/@cfgdirname@/${_pkgname}/g
    " -i "${srcdir}/${pkgname}.sh"
    install -Dm755 "${srcdir}/${pkgname}.sh" "${pkgdir}/usr/bin/${pkgname}"
    cd "$_pkgname/${_pkgname}-linux-${_arch}"
    install -Dm755 -d "${pkgdir}/usr/lib/${pkgname}"
    cp -a resources/. "${pkgdir}/usr/lib/${pkgname}/"
    install -Dm644 "../LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    install -Dm644 "../LICENSE-MIT" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-MIT"
    install -Dm644 "../packages/frontend/apps/electron/resources/icons/icon_stable_64x64.png" "${pkgdir}/usr/share/icons/hicolor/64x64/apps/${pkgname}.png"
    install -Dm644 "../packages/frontend/apps/electron/resources/icons/icon_stable_64x64.png" "${pkgdir}/usr/share/pixmaps/${pkgname}.png"
    install -Dm644 "${srcdir}/${pkgname}.desktop" -t "${pkgdir}/usr/share/applications"
}
