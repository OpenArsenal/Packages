pkgname=gitbutler-bin
_name=${pkgname%-bin}
pkgver=0.19.10
pkgrel=1
pkgdesc="Version control client, backed by Git, powered by Tauri/Rust/Svelte (prebuilt release)"
arch=('x86_64')
url='https://github.com/gitbutlerapp/gitbutler'
license=('LicenseRef-FSL-1.1-MIT')
provides=("${_name}=${pkgver}")
conflicts=('gitbutler' 'gitbutler-git')
depends=('bash' 'git' 'gtk3' 'hicolor-icon-theme' 'libayatana-appindicator' 'xdotool' 'openssl' 'webkit2gtk-4.1' 'xdg-utils')
options=('!strip')

source=("${_name}-${pkgver}.LICENSE.md::${url}/raw/refs/tags/release/${pkgver}/LICENSE.md"
  "gitbutler-flags-wrapper.sh")
source_x86_64=("GitButler-${pkgver}-1.x86_64.rpm::https://app.gitbutler.com/downloads/release/linux/x86_64/rpm")
sha256sums=('2a3154bf44e0b219014291b96249082f3305844a1d73796741468c8128c2829e'
            '9a34df546f30e5aa0e0c3309d0f4ce0b95af456936b2ef79223f6602d235e3bc')
sha256sums_x86_64=('d9562111dc0af5aa3b6f42bf9f2afb37fd8976df59d00095e0182c6774e98d63')
b2sums=('36777381aa01f14ac466a5bdad0603e5e1f15c8f7ab134ded4c1a827aedc6f7c192640e2321454ad0c206c57efb32d7e717c1268bb001098fba27202db1e53f0'
        'af6a176a6430a292c158f55573ac17fb543bed5af71a814d0ff0e34cf2c1fbc1892e477261b2150c51e1c89021b5e01b103700e4cc845ff143f6e9b80b3bed44')
b2sums_x86_64=('d8a7a39fe6d2d38888cd1657525863561195c02c3131b405d647ce0c488786fe8207bb1a55776b1dc4e47cf834396b74ec969a407e27054350a102d069065167')

_wrapper_target='/usr/lib/gitbutler/gitbutler-tauri'

_install_wrapper() {
  install -Dm755 /dev/null "${pkgdir}/usr/bin/gitbutler"
  sed -e "s#@GITBUTLER_EXEC@#${_wrapper_target}#g" \
    "${srcdir}/gitbutler-flags-wrapper.sh" >"${pkgdir}/usr/bin/gitbutler"

  ln -sf gitbutler "${pkgdir}/usr/bin/gitbutler-tauri"
  ln -sf gitbutler "${pkgdir}/usr/bin/but"
}

_fix_desktop_exec() {
  local _desktop

  while IFS= read -r -d '' _desktop; do
    sed -i 's#^Exec=gitbutler-tauri#Exec=gitbutler#' "${_desktop}"
  done < <(find "${pkgdir}/usr/share/applications" -type f -name '*.desktop' -print0 2>/dev/null)
}

prepare() {
  bsdtar -xf "GitButler-${pkgver}-1.${CARCH}.rpm"
}

package() {
  cp -a usr "${pkgdir}/"

  install -Dm755 "${pkgdir}/usr/bin/gitbutler-tauri" "${pkgdir}${_wrapper_target}"
  rm -f "${pkgdir}/usr/bin/gitbutler-tauri"
  _install_wrapper
  _fix_desktop_exec

  install -Dm644 "${_name}-${pkgver}.LICENSE.md" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE.md"
}
