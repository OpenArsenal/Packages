pkgname=gitbutler-git
_pkgname=${pkgname%-git}
pkgver=0.19.10.r104.g92ec892
pkgrel=1
pkgdesc="Version control client, backed by Git, powered by Tauri/Rust/Svelte (git version)"
arch=('x86_64')
url='https://github.com/gitbutlerapp/gitbutler'
license=('LicenseRef-FSL-1.1-MIT')
provides=("${_pkgname}")
conflicts=('gitbutler' 'gitbutler-bin')
options=('!lto')
depends=('git' 'gtk3' 'hicolor-icon-theme' 'libayatana-appindicator' 'xdotool' 'openssl' 'webkit2gtk-4.1' 'xdg-utils')
makedepends=('cargo' 'cmake' 'git' 'jq' 'nodejs' 'perl' 'pnpm' 'rust')

source=("${_pkgname}::git+${url}.git")
sha256sums=('SKIP')
b2sums=('SKIP')

pkgver() {
  cd "${srcdir}/${_pkgname}"
  git describe --tags --long --abbrev=7 --match 'release/*' | sed 's#^release/##;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd "${srcdir}/${_pkgname}"

  export COREPACK_ENABLE_DOWNLOAD_PROMPT=0
  export PNPM_HOME="${srcdir}/pnpm-home"
  export npm_config_cache="${srcdir}/npm-cache"
  export CARGO_HOME="${srcdir}/cargo-home"

  pnpm install --frozen-lockfile
}

build() {
  cd "${srcdir}/${_pkgname}"

  export COREPACK_ENABLE_DOWNLOAD_PROMPT=0
  export PNPM_HOME="${srcdir}/pnpm-home"
  export npm_config_cache="${srcdir}/npm-cache"
  export CARGO_HOME="${srcdir}/cargo-home"
  export CARGO_TARGET_DIR="${srcdir}/${_pkgname}/target"
  export CARGO_INCREMENTAL=0

  local _encoded_rustflags=''
  local _rustflag
  for _rustflag in ${RUSTFLAGS:-}; do
    _encoded_rustflags+="${_rustflag}"$'\x1f'
  done
  _encoded_rustflags+="--remap-path-prefix=${srcdir}/${_pkgname}=."$'\x1f'
  _encoded_rustflags+="--remap-path-prefix=${srcdir}=."$'\x1f'
  _encoded_rustflags+="--remap-path-prefix=${pkgdir}=."$'\x1f'
  export CARGO_ENCODED_RUSTFLAGS="${_encoded_rustflags%$'\x1f'}"
  unset RUSTFLAGS

  local _tauri_version
  _tauri_version="$(git describe --tags --abbrev=0 --match 'release/*' | sed 's#^release/##')"

  export VERSION="${_tauri_version}"
  export CHANNEL=release

  local _tauri_config="${srcdir}/tauri.conf.release.${pkgname}.json"
  jq --arg version "${_tauri_version}" '
    .version = $version
    | .bundle.externalBin = ["gitbutler-git-askpass"]
    | .bundle.createUpdaterArtifacts = false
    | del(.plugins.updater)
  ' crates/gitbutler-tauri/tauri.conf.release.json > "${_tauri_config}"

  pnpm tauri build \
    --features "builtin-but packaged-but-distribution disable-auto-updates" \
    --config "${_tauri_config}" \
    --bundles rpm
}

package() {
  cd "${srcdir}/${_pkgname}"

  local _rpm
  _rpm="$(find target/tauri/release/bundle/rpm target/release/bundle/rpm \
    -type f -name 'GitButler-*.x86_64.rpm' -print -quit 2>/dev/null)"

  bsdtar -xf "${_rpm}" -C "${pkgdir}"

  local _bin="${pkgdir}/usr/bin/gitbutler-tauri"
  if grep -aFq "${srcdir}" "${_bin}"; then
    local _srcdir_replacement
    printf -v _srcdir_replacement '%*s' "${#srcdir}" ''
    _srcdir_replacement="${_srcdir_replacement// /.}"
    SRC_DIR_REF="${srcdir}" SRC_DIR_REPL="${_srcdir_replacement}" \
      perl -0pi -e 's/\Q$ENV{SRC_DIR_REF}\E/$ENV{SRC_DIR_REPL}/g' "${_bin}"
  fi

  if grep -aFq "${srcdir}" "${_bin}"; then
    echo "ERROR: ${_bin} still contains a reference to \$srcdir" >&2
    return 1
  fi

  install -Dm644 LICENSE.md "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE.md"
}
