_nodeversion=22
_electron_version=41

pkgname=vesktop-electron
pkgver=1.6.5
pkgrel=1
pkgdesc="A standalone Electron-based Discord app with Vencord & improved Linux support (system Electron)"
arch=('x86_64' 'aarch64')
url="https://github.com/Vencord/Vesktop"
license=('GPL-3.0-only')
options=('!debug' '!strip')

_pkgsrc="Vesktop-${pkgver}"

provides=('vesktop')
conflicts=(
  'vesktop'
  'vesktop-git'
  'vesktop-bin'
  'vesktop-electron-git'
)
install='vesktop.install'

depends=(
