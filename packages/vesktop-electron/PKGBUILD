_approve_pnpm_builds() {
  python - <<'PYTHON_EOF'
from pathlib import Path

path = Path("pnpm-workspace.yaml")
if path.exists():
    lines = path.read_text().splitlines()
else:
    lines = []

if any(line.strip() == "- arrpc" for line in lines):
    raise SystemExit

for index, line in enumerate(lines):
    if line.strip() == "onlyBuiltDependencies:":
        indent = line[:len(line) - len(line.lstrip())]
        lines.insert(index + 1, f"{indent}  - arrpc")
        break
else:
    if lines and lines[-1].strip():
        lines.append("")
    lines.extend([
        "onlyBuiltDependencies:",
        "  - arrpc",
    ])

path.write_text("\n".join(lines) + "\n")
PYTHON_EOF
}

_nvm_env() {
  local _cache_root="${SRCDEST:-${srcdir}}"

  export HOME="${_cache_root}/${pkgname}-node-home"
  export XDG_CACHE_HOME="${HOME}/.cache"
  export XDG_CONFIG_HOME="${HOME}/.config"
  export XDG_DATA_HOME="${HOME}/.local/share"

  export NVM_DIR="${_cache_root}/${pkgname}-node-nvm"
  export ELECTRON_SKIP_BINARY_DOWNLOAD=1

  source /usr/share/nvm/init-nvm.sh || [[ $? != 1 ]]
  nvm install "${_nodeversion}"
  nvm use "${_nodeversion}"
}

_disable_root_postinstall() {
  node <<'EOF'
const fs = require("node:fs");
const pkg = JSON.parse(fs.readFileSync("package.json", "utf8"));
pkg.scripts ??= {};
pkg.scripts.postinstall = ":";
fs.writeFileSync("package.json", JSON.stringify(pkg, null, 2) + "\n");
EOF
}

prepare() {
  _nvm_env

  cd "${srcdir}/${_pkgsrc}"
  _disable_root_postinstall
}

build() {
  _nvm_env

  cd "${srcdir}/${_pkgsrc}"

  export ELECTRON_OVERRIDE_DIST_PATH="/usr/lib/electron${_electron_version}"
  export ELECTRON_DIST="${ELECTRON_OVERRIDE_DIST_PATH}"

  _approve_pnpm_builds
  pnpm install --frozen-lockfile
  pnpm updateArrpcDB
  pnpm build
  pnpm exec electron-builder --dir --config "${srcdir}/electron-builder-config.cjs"
}

package() {
  local _electron_version_full
  local _app_asar

  _electron_version_full="$(<"/usr/lib/electron${_electron_version}/version")"
  _electron_version_full="${_electron_version_full#v}"

  cd "${srcdir}/${_pkgsrc}"

  _app_asar="$(find dist -path '*/resources/app.asar' -print -quit)"

  [[ -n "${_app_asar}" && -f "${_app_asar}" ]] || {
    printf '%s\n' "ERROR: could not locate Vesktop app.asar."
    return 1
  }

  install -Dm644 "${_app_asar}" "${pkgdir}/usr/lib/vesktop/app.asar"
  install -Dm644 "${srcdir}/vesktop.desktop" "${pkgdir}/usr/share/applications/vesktop.desktop"
  install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 "build/icon.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/vesktop.svg"

  sed -e "s#@ELECTRON_CMD@#/usr/bin/electron${_electron_version}#g" -e "s#@VESKTOP_APP@#/usr/lib/vesktop/app.asar#g" "${srcdir}/vesktop-flags-wrapper.sh" >"${srcdir}/vesktop"

  if grep -q '@[A-Z_][A-Z_]*@' "${srcdir}/vesktop"; then
    printf '%s\n' "ERROR: unresolved wrapper placeholder(s):"
    grep -n '@[A-Z_][A-Z_]*@' "${srcdir}/vesktop"
    return 1
  fi

  install -Dm755 "${srcdir}/vesktop" "${pkgdir}/usr/bin/vesktop"
  install -Dm644 /dev/stdin "${pkgdir}/usr/lib/vesktop/electron_version" <<<"${_electron_version_full}"

  chmod -R u=rwX,go=rX "${pkgdir}"
}
