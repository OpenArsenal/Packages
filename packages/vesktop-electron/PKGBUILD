  'zlib'
)

makedepends=(
  'nvm'
  'pnpm'
)

source=(
  "${_pkgsrc}.tar.gz::${url}/archive/v${pkgver}.tar.gz"
  'vesktop.desktop'
  'vesktop-flags-wrapper.sh'
  'electron-builder-config.cjs'
