#!/usr/bin/env bash

XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-"$HOME/.config"}

# Allow users to override command-line options
if [[ -f "$XDG_CONFIG_HOME/positron-flags.conf" ]]; then
  POSITRON_USER_FLAGS="$(sed 's/#.*//' "$XDG_CONFIG_HOME/positron-flags.conf" | tr '\n' ' ')"
fi

exec /usr/share/positron/bin/positron "$@" ${POSITRON_USER_FLAGS}
