# Maintainer: Okiki <okiki@thunderstrike.co>

pkgname=vivaldi-ffmpeg-git
pkgver=8.2.dev.r1512.g8df8f8b1bb
pkgrel=1
pkgdesc="Additional proprietary codec support for Vivaldi (FFmpeg git HEAD)"
arch=('x86_64')
url=https://git.ffmpeg.org/ffmpeg
_chromium_ffmpeg_url=https://chromium.googlesource.com/chromium/third_party/ffmpeg
license=('LGPL-2.1-or-later')
_so=libffmpeg.so
_vivaldi_ffmpeg_suffix=8.0

# Chromium master ffmpeg.sigs, for the VCS build.
_chromium_ffmpeg_ref=refs/heads/master

source=(
  "ffmpeg::git+${url}.git"
  "sigs.base64::${_chromium_ffmpeg_url}/+/${_chromium_ffmpeg_ref}/chromium/ffmpeg.sigs?format=TEXT"
  "0001-Add-av_stream_get_first_dts-for-Chromium.patch::https://gitlab.archlinux.org/archlinux/packaging/packages/ffmpeg/-/raw/main/0001-Add-av_stream_get_first_dts-for-Chromium.patch"
)

sha256sums=('SKIP'
            '0b5cb2ff097869916b6d050c81e278985c9ad752fabcf2f9f39487574709b853'
            'f865d677f8ad39c79dde69186629cb6468c2b289c4156dbb8dec8e68b0131b40')
b2sums=('SKIP'
        '046f7fcb32ccd2d18a8a85a6ef4e1445cb6af682fb75999b12b60cd900fc4d37962dd86fc3f0201ec23ba296a834a01139ba379fabb33b1b49fa331a876593d5'
        'e5f7b79f7731be9ee5a7280a9221fb531ac5a2d9820fc5870b68b0eabea667dfbe8f39f41c1e1763a4c84982896afaa54c81ff57847d203b70afafd726689e5d')

depends=(glibc)
makedepends=(git nasm)
options=('!lto')

conflicts=("${pkgname%-git}" vivaldi-ffmpeg-codecs)
provides=("${pkgname%-git}" vivaldi-ffmpeg-codecs)

pkgver() {
  cd ffmpeg
  git describe --tags --long |
    sed -E 's/^n//;s/-([0-9]+)-g([0-9a-f]+)$/.r\1.g\2/;s/-/./g'
}

prepare() {
  # List Chromium-used FFmpeg functions.
  base64 -d sigs.base64 |
    grep -oP '\bav[a-z0-9_]*(?=\s*\()' |
    sort -u >sigs.txt

  sort -u -o sigs.txt sigs.txt

  {
    printf '{\nglobal:\n'
    sed 's/$/;/' sigs.txt
    printf 'local:\n*;\n};\n'
  } >export.map

  cd ffmpeg

  # Use native opus not in kAllowedAudioCodecs.
  sed -i.bak 's/^ *\.p\.name *=.*/.p.name="libopus",/' libavcodec/opus/dec.c

  # Arch/Chromium compatibility patch: export av_stream_get_first_dts().
  patch -Np1 -i ../0001-Add-av_stream_get_first_dts-for-Chromium.patch

  # Chromium compatibility edits. These are no-ops if the patterns are absent.
  sed -i.bak '/ff_aom_uninit_film_grain_params/d' libavcodec/h2645_sei.c
  sed -i.bak -E \
    -e '/&ff_dirac_codec,/d' \
    -e '/&ff_speex_codec,/d' \
    -e '/&ff_theora_codec,/d' \
    -e '/&ff_celt_codec,/d' \
    -e '/&ff_old_dirac_codec,/d' \
    libavformat/oggdec.c
  sed -i.bak 's/^int av_sscanf(.*/#define av_sscanf sscanf/' libavutil/avstring.h

  # CHROMIUM_NO_LOGGING.
  _av_log=$(grep -m1 -E '^void[[:space:]]+av_log\(' libavutil/log.c)
  _av_log_once=$(grep -m1 -E '^void[[:space:]]+av_log_once\(' libavutil/log.c)
  _av_vlog=$(grep -m1 -E '^void[[:space:]]+av_vlog\(' libavutil/log.c)

  sed -i.bak -E \
    '/^void[[:space:]]+(av_log|av_log_once|av_vlog)[[:space:]]*\(.*\)[[:space:]]*$/,/^[[:space:]]*}[[:space:]]*$/d' \
    libavutil/log.c

  printf '%s{}\n%s{}\n%s{}\n' \
    "${_av_log}" \
    "${_av_log_once}" \
    "${_av_vlog}" >>libavutil/log.c
}

build() {
  cd ffmpeg

  ./configure \
    --disable-{debug,all,autodetect,doc,iconv,network,symver,large-tests} \
    --disable-{error-resilience,faan,iamf} \
    --enable-static \
    --disable-shared \
    --enable-av{format,codec,util} \
    --enable-swresample \
    --enable-demuxers \
    --enable-decoders \
    --enable-parsers \
    --extra-cflags="-fno-math-errno -fno-signed-zeros -fno-semantic-interposition -fomit-frame-pointer" \
    --enable-{pic,asm,hardcoded-tables} \
    --libdir=/

  make DESTDIR=.. install

  cd ..
  _symbols=$(sed 's/^/-Wl,-u,/' sigs.txt | paste -sd ' ' -)

  gcc -shared $LDFLAGS \
    -Wl,--start-group libav{codec,format,util}.a libswresample.a -Wl,--end-group \
    ${_symbols} \
    -Wl,--version-script=export.map \
    -lm \
    -Wl,-Bsymbolic \
    -o "${_so}"
}

package() {
  install -Dm755 "${_so}" "${pkgdir}/opt/vivaldi/${_so}.${_vivaldi_ffmpeg_suffix}"
}
