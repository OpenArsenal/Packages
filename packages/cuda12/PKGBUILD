prepare() {
  cd "${srcdir}"

  chmod +x "cuda_${pkgver}_${_driverver}_linux.run"
  sh "./cuda_${pkgver}_${_driverver}_linux.run" --target "${srcdir}" --noexec

  # If you ever re-enable this, do it safely:
  # while IFS= read -r -d '' f; do
  #   patch --no-backup-if-mismatch "${f}" < "${srcdir}/cuda-findgllib_mk.diff"
  # done < <(find "${srcdir}/builds/cuda_samples" -name findgllib.mk -print0)
}

_apply_common_fixes() {
  local cuda_root="${pkgdir}/opt/cuda"
  local targets_dir="${cuda_root}/targets/${CARCH}-linux"
  local host_cfg="${targets_dir}/include/crt/host_config.h"
  local cupti_root=
  local broken

  if [[ -f "${host_cfg}" ]]; then
    sed -i '/.*unsupported GNU version.*/d' "${host_cfg}"
    sed -i '/.*unsupported clang version.*/d' "${host_cfg}"
  fi

  while IFS= read -r -d '' f; do
    sed -i 's|/usr/local/cuda|/opt/cuda|g' "${f}"
  done < <(find "${cuda_root}" -name Makefile -print0)

  if [[ -d "${cuda_root}/cuda_sanitizer_api/compute-sanitizer" && ! -e "${cuda_root}/compute-sanitizer" ]]; then
    mv "${cuda_root}/cuda_sanitizer_api/compute-sanitizer" "${cuda_root}/compute-sanitizer"
    rmdir --ignore-fail-on-non-empty "${cuda_root}/cuda_sanitizer_api" 2>/dev/null || true
  fi

  if [[ -x "${cuda_root}/compute-sanitizer/compute-sanitizer" && ! -e "${cuda_root}/bin/compute-sanitizer" ]]; then
    install -d "${cuda_root}/bin"
    ln -s ../compute-sanitizer/compute-sanitizer "${cuda_root}/bin/compute-sanitizer"
  fi

  if [[ -d "${targets_dir}/include" && ! -e "${cuda_root}/include" ]]; then
    ln -s "targets/${CARCH}-linux/include" "${cuda_root}/include"
  fi
  if [[ -d "${targets_dir}/lib" && ! -e "${cuda_root}/lib64" ]]; then
    ln -s "targets/${CARCH}-linux/lib" "${cuda_root}/lib64"
  fi
  if [[ -e "${cuda_root}/lib64" && ! -e "${cuda_root}/lib" ]]; then
    ln -s lib64 "${cuda_root}/lib"
  fi

  for candidate in "${cuda_root}/extras/CUPTI" "${cuda_root}/CUPTI"; do
    if [[ -d "${candidate}" ]]; then
      cupti_root="${candidate}"
      break
    fi
  done

  if [[ -n "${cupti_root}" ]]; then
    if [[ -d "${cupti_root}/include" ]]; then
      install -d "${targets_dir}/include"
      cp -a "${cupti_root}/include/." "${targets_dir}/include/"
      rm -rf "${cupti_root}/include"
    fi
    if [[ -d "${cupti_root}/lib64" ]]; then
      install -d "${targets_dir}/lib"
      cp -a "${cupti_root}/lib64/." "${targets_dir}/lib/"
      rm -rf "${cupti_root}/lib64"
    fi
    rmdir --ignore-fail-on-non-empty "${cupti_root}" 2>/dev/null || true
    rmdir --ignore-fail-on-non-empty "${cuda_root}/extras" 2>/dev/null || true
  fi

  for broken in     "${cuda_root}/include/include"     "${cuda_root}/lib64/lib64"     "${targets_dir}/include/include"     "${targets_dir}/lib/lib"     "${targets_dir}/lib64/lib64"
  do
    [[ -L "${broken}" && ! -e "${broken}" ]] && rm -f "${broken}"
  done

  patch -p1 -d "${pkgdir}" -i "${srcdir}/fix-glibc241.patch" --no-backup-if-mismatch
  patch -p1 -d "${pkgdir}" -i "${srcdir}/fix-glibc242.patch" --no-backup-if-mismatch

  if [[ -d "${targets_dir}" ]]; then
    patch -p2 -d "${targets_dir}" -i "${srcdir}/4972.patch" --no-backup-if-mismatch
  fi
}

_package_base_tree() {
  local entry

  cd "${srcdir}/builds"

  install -d "${pkgdir}/opt/cuda"
  install -d "${pkgdir}/opt/cuda/extras"

  for entry in integration nsight_compute nsight_systems EULA.txt; do
    [[ -e "${entry}" ]] && cp -a -- "${entry}" "${pkgdir}/opt/cuda/"
  done

  shopt -s nullglob dotglob
  for entry in *; do
    [[ -d "${entry}" ]] || continue
    case "${entry}" in
      integration|nsight_compute|nsight_systems)
        continue
        ;;
    esac
    cp -a -- "${entry}/." "${pkgdir}/opt/cuda/"
  done
  shopt -u nullglob dotglob
}

_install_core_shell_env() {
  install -Dm755 "${srcdir}/cuda.sh" "${pkgdir}/etc/profile.d/cuda.sh"
  install -Dm644 "${srcdir}/cuda.fish" "${pkgdir}/etc/fish/conf.d/cuda.fish"
}

_install_nsight_compute_shell_env() {
  install -Dm755 "${srcdir}/cuda-nsight-compute.sh" "${pkgdir}/etc/profile.d/cuda-nsight-compute.sh"
  install -Dm644 "${srcdir}/cuda-nsight-compute.fish" "${pkgdir}/etc/fish/conf.d/cuda-nsight-compute.fish"
}

_install_nsight_systems_shell_env() {
  install -Dm755 "${srcdir}/cuda-nsight-systems.sh" "${pkgdir}/etc/profile.d/cuda-nsight-systems.sh"
  install -Dm644 "${srcdir}/cuda-nsight-systems.fish" "${pkgdir}/etc/fish/conf.d/cuda-nsight-systems.fish"
}

_install_eula_license() {
  install -d "${pkgdir}/usr/share/licenses/${pkgname}"
  ln -s /opt/cuda/doc/pdf/EULA.pdf "${pkgdir}/usr/share/licenses/${pkgname}/EULA.pdf"
}

_install_common_metadata() {
  _install_core_shell_env
  install -Dm644 "${srcdir}/cuda.conf" "${pkgdir}/etc/ld.so.conf.d/cuda.conf"
  _install_eula_license
}

_install_pkgconfig_files() {
  local pc

  install -d "${pkgdir}/usr/lib/pkgconfig"
  shopt -s nullglob
  for pc in "${srcdir}"/*.pc; do
    install -Dm644 "${pc}" "${pkgdir}/usr/lib/pkgconfig/$(basename "${pc}")"
  done
  shopt -u nullglob
}


_fix_nsight_host_rpaths() {
  local root="$1"
  local f
  local rpath='$ORIGIN:$ORIGIN/..:$ORIGIN/../..:$ORIGIN/../../..'

  [[ -d "${root}" ]] || return 0

  while IFS= read -r -d '' f; do
    if readelf -h "${f}" >/dev/null 2>&1; then
      patchelf --set-rpath "${rpath}" "${f}"
    fi
  done < <(find "${root}" -type f \( -name '*.so' -o -name '*.so.*' -o -perm -u+x \) -print0)
}

package_cuda12() {
  pkgdesc='NVIDIA CUDA 12 core toolkit'
  depends=('opencl-nvidia' 'nvidia-utils' 'python' 'gcc')
  optdepends=(
    'gdb: for cuda-gdb'
    'cuda12-profiler: legacy nvprof/nvvp tools'
    'cuda12-nsight-compute: Nsight Compute profiler'
    'cuda12-nsight-systems: Nsight Systems profiler'
  )
  conflicts=('cuda')
  replaces=('cuda-toolkit' 'cuda-sdk')
  provides=("cuda=${pkgver}" "cuda-toolkit=${pkgver}" "cuda-sdk=${pkgver}")
  options=(!strip staticlibs)
  install=cuda.install
  backup=(
    'etc/profile.d/cuda.sh'
    'etc/fish/conf.d/cuda.fish'
    'etc/ld.so.conf.d/cuda.conf'
  )

  cd "${srcdir}"

  _package_base_tree

  rm -rf "${pkgdir}/opt/cuda/NVIDIA"*.run

  # Split out Nsight payloads from the core package.
  rm -rf "${pkgdir}/opt/cuda/nsight_compute"
  rm -rf "${pkgdir}/opt/cuda/nsight_systems"

  # Also remove compatibility paths from the core package so the split packages can own them.
  rm -rf "${pkgdir}/opt/cuda/integration/nsight-compute"
  rm -rf "${pkgdir}/opt/cuda/integration/nsight-systems"
  rm -rf "${pkgdir}/opt/cuda/integration/nsight_compute"
  rm -rf "${pkgdir}/opt/cuda/integration/nsight_systems"

  rm -f "${pkgdir}/opt/cuda/bin/cuda-uninstaller"
  rm -f "${pkgdir}/opt/cuda/cuda-uninstaller"
  rm -f "${pkgdir}/opt/cuda/ko-uninstaller"
  rm -f "${pkgdir}/opt/cuda/bin/cuda-gdb-python3."*-tui

  rm -f "${pkgdir}/opt/cuda/bin/computeprof"
  rm -f "${pkgdir}/opt/cuda/bin/nvprof"
  rm -f "${pkgdir}/opt/cuda/bin/nvvp"
  rm -rf "${pkgdir}/opt/cuda/libnvvp"
  rm -f "${pkgdir}/opt/cuda/doc/man/man1/computeprof.1.gz"
  rm -f "${pkgdir}/opt/cuda/doc/man/man1/nvprof.1.gz"
  rm -f "${pkgdir}/opt/cuda/doc/man/man1/nvvp.1.gz"

  [[ -e "${pkgdir}/opt/cuda/bin/gcc" ]] || ln -s /usr/bin/gcc "${pkgdir}/opt/cuda/bin/gcc"
  [[ -e "${pkgdir}/opt/cuda/bin/g++" ]] || ln -s /usr/bin/g++ "${pkgdir}/opt/cuda/bin/g++"

  _install_pkgconfig_files
  _install_common_metadata
  _apply_common_fixes
}

package_cuda12-profiler() {
  pkgdesc='NVIDIA legacy profiler tools for CUDA 12'
  depends=('cuda12')
  options=(!strip)

  cd "${srcdir}"

  _package_base_tree

  rm -rf "${pkgdir}/opt/cuda/NVIDIA"*.run
  rm -rf "${pkgdir}/opt/cuda/nsight_compute"
  rm -rf "${pkgdir}/opt/cuda/nsight_systems"
  rm -rf "${pkgdir}/opt/cuda/integration"
  rm -f "${pkgdir}/opt/cuda/bin/cuda-uninstaller"
  rm -f "${pkgdir}/opt/cuda/cuda-uninstaller"
  rm -f "${pkgdir}/opt/cuda/ko-uninstaller"
  rm -f "${pkgdir}/opt/cuda/bin/cuda-gdb-python3."*-tui

  find "${pkgdir}/opt/cuda" -mindepth 1 -maxdepth 1     ! -name bin     ! -name libnvvp     ! -name doc     -exec rm -rf {} +

  if [[ -d "${pkgdir}/opt/cuda/bin" ]]; then
    find "${pkgdir}/opt/cuda/bin" -mindepth 1 -maxdepth 1       ! -name computeprof       ! -name nvprof       ! -name nvvp       -exec rm -rf {} +
  fi

  if [[ -d "${pkgdir}/opt/cuda/doc" ]]; then
    find "${pkgdir}/opt/cuda/doc" -mindepth 1 -maxdepth 1       ! -name man       ! -name pdf       -exec rm -rf {} +
  fi

  if [[ -d "${pkgdir}/opt/cuda/doc/man" ]]; then
    find "${pkgdir}/opt/cuda/doc/man" -mindepth 1 -maxdepth 1       ! -name man1       -exec rm -rf {} +
  fi

  if [[ -d "${pkgdir}/opt/cuda/doc/man/man1" ]]; then
    find "${pkgdir}/opt/cuda/doc/man/man1" -mindepth 1 -maxdepth 1       ! -name computeprof.1.gz       ! -name nvprof.1.gz       ! -name nvvp.1.gz       -exec rm -rf {} +
  fi

  _install_eula_license
}

package_cuda12-nsight-systems() {
  pkgdesc='NVIDIA Nsight Systems for CUDA 12'
  depends=('cuda12' 'jre-openjdk')
  options=(!strip)
  backup=(
    'etc/profile.d/cuda-nsight-systems.sh'
    'etc/fish/conf.d/cuda-nsight-systems.fish'
  )

  cd "${srcdir}"

  install -d "${pkgdir}/opt/cuda"
  install -d "${pkgdir}/opt/cuda/integration"

  if [[ -d "${srcdir}/builds/nsight_systems" ]]; then
    cp -a "${srcdir}/builds/nsight_systems" "${pkgdir}/opt/cuda/"
  fi

  # Compatibility path expected by NVIDIA launcher scripts.
  ln -sfn ../nsight_systems "${pkgdir}/opt/cuda/integration/nsight-systems"

  _fix_nsight_host_rpaths "${pkgdir}/opt/cuda/nsight_systems/host-linux-x64"

  _install_nsight_systems_shell_env
  _install_eula_license
}

package_cuda12-nsight-compute() {
  pkgdesc='NVIDIA Nsight Compute for CUDA 12'
  depends=('cuda12' 'jre-openjdk')
  options=(!strip)
  backup=(
    'etc/profile.d/cuda-nsight-compute.sh'
    'etc/fish/conf.d/cuda-nsight-compute.fish'
  )

  cd "${srcdir}"

  install -d "${pkgdir}/opt/cuda"
  install -d "${pkgdir}/opt/cuda/integration"

  if [[ -d "${srcdir}/builds/nsight_compute" ]]; then
    cp -a "${srcdir}/builds/nsight_compute" "${pkgdir}/opt/cuda/"
  fi

  # Compatibility path expected by NVIDIA launcher scripts.
  ln -sfn ../nsight_compute "${pkgdir}/opt/cuda/integration/nsight-compute"

  _fix_nsight_host_rpaths "${pkgdir}/opt/cuda/nsight_compute/host/linux-desktop-glibc_2_11_3-x64"

  _install_nsight_compute_shell_env
  _install_eula_license
}

