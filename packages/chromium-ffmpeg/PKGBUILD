pkgname=chromium-ffmpeg
_ffmpeg_pkgver=8.1.1
_avcodec=62
pkgrel=1
pkgdesc="Add codecs to Chromium (libavcodec ${_avcodec})"
arch=('x86_64')
url=https://ffmpeg.org/
_chromium_ffmpeg_url=https://chromium.googlesource.com/chromium/third_party/ffmpeg
license=('LGPL-2.1-or-later')
_so=libffmpeg.so

# Chromium 149.0.7827.53 third_party/ffmpeg submodule commit.
# For newer Chromium majors, use update-ffmpeg-ref.sh to update this commit and run updpkgsums.
_chromium_version=149.0.7827.53
_chromium_ffmpeg_ref=f45bab87ce4c5fafc67fd53fcde777578d01bfa0

pkgver=${_ffmpeg_pkgver}_${_chromium_version}

source=(
  "${url}releases/ffmpeg-${_ffmpeg_pkgver}.tar.xz"
  "sigs.base64::${_chromium_ffmpeg_url}/+/${_chromium_ffmpeg_ref}/chromium/ffmpeg.sigs?format=TEXT"
  "https://gitlab.archlinux.org/archlinux/packaging/packages/ffmpeg/-/raw/2-${_ffmpeg_pkgver}-1/0001-Add-av_stream_get_first_dts-for-Chromium.patch"
)

sha256sums=('b6863adde98898f42602017462871b5f6333e65aec803fdd7a6308639c52edf3'
            '9aa34221682c13cf5c55b3ceabf8c26c887d95569f51fb73fed0691fec08b56f'
            'f865d677f8ad39c79dde69186629cb6468c2b289c4156dbb8dec8e68b0131b40')
b2sums=('275f853672f5d8e84bed0cd98b272b576355ebb3d31ad0538ef40200cf319ac03bd10d18f67b29e8549910e7e089aef7bad1c9537ae025eae5c13fc3c4bdb6c9'
        'c92deb468a018ae7f04150d35cb71d3cf7e2e151f23ab84533bca9ccb0c678b94897668c48362aa6549cfa9127250e094719a14f95b59ed4e95f69dcebb3bca1'
        'e5f7b79f7731be9ee5a7280a9221fb531ac5a2d9820fc5870b68b0eabea667dfbe8f39f41c1e1763a4c84982896afaa54c81ff57847d203b70afafd726689e5d')

depends=(glibc)
makedepends=(nasm)
options=('!lto')

conflicts=('chromium-ffmpeg-git')
provides=('chromium-ffmpeg')

prepare() {
  # List used functions from Chromium's ffmpeg.sigs for the selected Chromium tag.
  base64 -d sigs.base64 |
    grep -oP '\bav[a-z0-9_]*(?=\s*\()' |
    sort -u >sigs.txt

  sort -u -o sigs.txt sigs.txt

  {
    printf '{\nglobal:\n'
    sed 's/$/;/' sigs.txt
    printf 'local:\n*;\n};\n'
  } >export.map

  cd "ffmpeg-${_ffmpeg_pkgver}"

  # Use native opus not in kAllowedAudioCodecs.
  sed -i.bak 's/^ *\.p\.name *=.*/.p.name="libopus",/' libavcodec/opus/dec.c

  # Chromium patches.
  patch -Np1 -i ../0001-Add-av_stream_get_first_dts-for-Chromium.patch
  sed -i.bak '/ff_aom_uninit_film_grain_params/d' libavcodec/h2645_sei.c
  sed -i.bak -E \
    -e '/&ff_dirac_codec,/d' \
    -e '/&ff_speex_codec,/d' \
    -e '/&ff_theora_codec,/d' \
    -e '/&ff_celt_codec,/d' \
    -e '/&ff_old_dirac_codec,/d' \
    libavformat/oggdec.c
  sed -i.bak 's/^int av_sscanf(.*/#define av_sscanf sscanf/' libavutil/avstring.h

  # CHROMIUM_NO_LOGGING.
  _av_log=$(grep -m1 -E '^void[[:space:]]+av_log\(' libavutil/log.c)
  _av_log_once=$(grep -m1 -E '^void[[:space:]]+av_log_once\(' libavutil/log.c)
  _av_vlog=$(grep -m1 -E '^void[[:space:]]+av_vlog\(' libavutil/log.c)

  sed -i.bak -E \
    '/^void[[:space:]]+(av_log|av_log_once|av_vlog)[[:space:]]*\(.*\)[[:space:]]*$/,/^[[:space:]]*}[[:space:]]*$/d' \
    libavutil/log.c

  printf '%s{}\n%s{}\n%s{}\n' \
    "${_av_log}" \
    "${_av_log_once}" \
    "${_av_vlog}" >>libavutil/log.c
}

build() {
  cd "ffmpeg-${_ffmpeg_pkgver}"

  ./configure \
    --disable-{debug,all,autodetect,doc,iconv,network,symver,large-tests} \
    --disable-{error-resilience,faan,iamf} \
    --enable-static \
    --disable-shared \
    --enable-av{format,codec,util} \
    --enable-swresample \
    --enable-demuxers \
    --enable-decoders \
    --enable-parsers \
    --extra-cflags="-fno-math-errno -fno-signed-zeros -fno-semantic-interposition -fomit-frame-pointer" \
    --enable-{pic,asm,hardcoded-tables} \
    --libdir=/

  make DESTDIR=.. install

  cd ..
  _symbols=$(sed 's/^/-Wl,-u,/' sigs.txt | paste -sd ' ' -)

  gcc -shared $LDFLAGS \
    -Wl,--start-group libav{codec,format,util}.a libswresample.a -Wl,--end-group \
    ${_symbols} \
    -Wl,--version-script=export.map \
    -lm \
    -Wl,-Bsymbolic \
    -o "${_so}"
}

package() {
  install -Dm755 "${_so}" "${pkgdir}/usr/lib/${_so}.${_avcodec}"
  ln -sf "${_so}.${_avcodec}" "${pkgdir}/usr/lib/${_so}"
}
