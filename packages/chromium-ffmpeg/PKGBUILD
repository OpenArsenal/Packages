pkgname=chromium-ffmpeg
_avcodec=62
pkgver=8.1.1
pkgrel=1
pkgdesc="Add codecs to Chromium M138+ (libavcodec ${_avcodec})"
arch=('x86_64')
url=https://ffmpeg.org/
_url=https://chromium.googlesource.com/chromium/third_party/ffmpeg
license=('LGPL-2.1-or-later')
install=chromium-ffmpeg.install
_so=libffmpeg.so

# Chromium 138.0.7204.101 third_party/ffmpeg submodule commit.
# For newer Chromium majors, update this commit and run updpkgsums.
_chromium_ffmpeg_ref=dcdd0fa51b65a0b1688ff6b8f0cc81908f09ded2

source=(
  "${install}"
  "${pkgname}.hook"
  "${url}releases/ffmpeg-${pkgver}.tar.xz"
  "sigs.base64::${_url}/+/${_chromium_ffmpeg_ref}/chromium/ffmpeg.sigs?format=TEXT"
  "https://gitlab.archlinux.org/archlinux/packaging/packages/ffmpeg/-/raw/2-${pkgver}-1/0001-Add-av_stream_get_first_dts-for-Chromium.patch"
)

sha256sums=('2726a8abe72d73bab070f0868c653fc5b8aa6f0697ddb1d6bd3adbefdd6fd425'
  'f3371c17a935787a17e949cd87c2a4527058eb220c4c8b1719ca7915e64092d0'
