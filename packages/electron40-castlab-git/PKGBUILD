pkgname=electron40-castlab-git
pkgver=40.10.2.r0.g9f9f654
pkgrel=1
pkgdesc='Electron 40 for Content Security by castLabs with Widevine CDM support - git wrapper package'
arch=('x86_64')
url='https://github.com/castlabs/electron-releases'
license=('MIT')
depends=(
  'brotli'
  'c-ares'
  'flac'
  'fontconfig'
  'freetype2'
  'gcc-libs'
  'glibc'
  'gtk3'
  'harfbuzz'
  'libdrm'
  'libevent'
  'libffi'
  'libjpeg-turbo'
  'libpulse'
  'libxml2'
  'libxslt'
  'minizip'
  'nss'
  'opus'
  'zlib'
)
makedepends=('git' 'libarchive')
optdepends=(
  'gtk4: for --gtk-version=4'
  'kde-cli-tools: file deletion support via kioclient'
  'pipewire: WebRTC desktop sharing under Wayland'
  'trash-cli: file deletion support via trash-put'
  'xdg-utils: open URLs with the desktop default handler'
)
provides=('electron40-castlab' 'electron-castlab')
conflicts=('electron40-castlab' 'electron40-castlab-bin')
options=('!strip' '!debug')

_variant='wvcus'
_release_ver='40.10.2'
_upstream_ver="${_release_ver}+${_variant}"
_zip="electron-v${_upstream_ver}-linux-x64.zip"
source=('electron-releases::git+https://github.com/castlabs/electron-releases.git#branch=40-x-y')
source_x86_64=("${_zip}::${url}/releases/download/v${_release_ver}%2B${_variant}/${_zip}")
sha256sums=('SKIP')
sha256sums_x86_64=('e179c0b4134e32e59a2c87e09e5086cce4c33928333565add57f16e865dd224d')
b2sums=('SKIP')
b2sums_x86_64=('c470e0ee6599342a9e1d5ccaccba7987ccc63887b3e854ba36a43133ea5347136ad0043ed808b01bb9ba6e09bafedbe546dcbbee9af93155021fcf8a3b21a598')
noextract=("${_zip}")

pkgver() {
  cd electron-releases
  git describe --tags --long --abbrev=7 --match 'v40.*+wvcus' 2>/dev/null |
    sed 's/^v//;s/+wvcus//;s/-/.r/;s/-/./g' || printf '%s.r0.g0000000' "${_release_ver}"
}

package() {
  install -dm755 "${pkgdir}/usr/lib/electron40-castlab"
  bsdtar -xf "${srcdir}/${_zip}" -C "${pkgdir}/usr/lib/electron40-castlab"

  chmod 755 "${pkgdir}/usr/lib/electron40-castlab/electron"
  if [[ -f "${pkgdir}/usr/lib/electron40-castlab/chrome-sandbox" ]]; then
    chmod 4755 "${pkgdir}/usr/lib/electron40-castlab/chrome-sandbox"
  fi

  install -Dm755 /dev/stdin "${pkgdir}/usr/bin/electron40-castlab" <<'LAUNCHER'
#!/bin/sh
exec /usr/lib/electron40-castlab/electron "$@"
LAUNCHER

  ln -s electron40-castlab "${pkgdir}/usr/bin/electron-castlab"
  install -Dm644 "${srcdir}/electron-releases/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
