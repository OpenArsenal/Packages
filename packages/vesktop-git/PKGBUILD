_nodeversion=22

pkgname=vesktop-git
pkgver=1.6.5.r542.g61ecf66
pkgrel=1
pkgdesc="A standalone Electron-based Discord app with Vencord & improved Linux support (git version; bundled Electron)"
arch=('x86_64' 'aarch64')
url="https://github.com/Vencord/Vesktop"
license=('GPL-3.0-only')
options=('!debug' '!strip')

_repo="https://github.com/Vencord/Vesktop.git"
_branch="main"

_pkgsrc="${pkgname}"

provides=('vesktop')
conflicts=(
  'vesktop'
  'vesktop-bin'
  'vesktop-electron'
  'vesktop-electron-git'
)
install='vesktop.install'

depends=(
  'alsa-lib'
