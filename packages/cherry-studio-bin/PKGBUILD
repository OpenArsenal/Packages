_pkgname=cherry-studio
pkgver=1.9.6
pkgrel=1
pkgdesc="Desktop client for multiple LLM providers (prebuilt release; bundled Electron)"
arch=('x86_64')
url="https://github.com/cherryHQ/cherry-studio"
license=('AGPL-3.0-only')
options=('!strip' '!debug')
makedepends=('asar')
depends=(
  'alsa-lib'
  'at-spi2-core'
  'atk'
  'bash'
  'cairo'
  'cups'
  'dbus'
  'expat'
  'gcc-libs'
  'glib2'
  'glibc'
  'gtk3'
  'libevdev'
  'libdrm'
  'libx11'
  'libxcb'
  'libxcomposite'
  'libxdamage'
  'libxext'
  'libxfixes'
  'libxkbcommon'
  'libxrandr'
  'mesa'
  'nspr'
  'nss'
  'pango'
  'systemd-libs'
)
optdepends=(
  'libnotify: desktop notifications'
  'ollama: use your local LLM'
  'xdg-utils: open links in the default desktop applications'
)
provides=("${pkgname%-bin}=${pkgver}")
conflicts=("${pkgname%-bin}")
source=(
  "${_pkgname}-${pkgver}.AppImage::${url}/releases/download/v${pkgver}/Cherry-Studio-${pkgver}-${arch}.AppImage"
  "LICENSE-${pkgver}::${url}/raw/v${pkgver}/LICENSE"
  "${pkgname}.sh"
)
noextract=("${_pkgname}-${pkgver}.AppImage")
sha256sums=('26dfbcec03195ffbc5a5dc9d15f65a20250fa1e6f472f5cb26d97171e71d8e27'
