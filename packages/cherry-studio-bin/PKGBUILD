_remove_updater_metadata() {
  local _root="$1"

  [[ -d "${_root}" ]] || return 0

  find "${_root}" -type f \( \
    -name 'app-update.yml' -o \
    -name 'dev-app-update.yml' -o \
    -name 'latest*.yml' \
  \) -delete 2>/dev/null || true
}

_patch_packed_app() {
  local _asar="$1"
  local _extract_dir="$2"

  [[ -f "${_asar}" ]] || return 0

  rm -rf "${_extract_dir}"
  asar extract "${_asar}" "${_extract_dir}"

  node - "${_extract_dir}" <<'EOF'
const fs = require('fs')
const path = require('path')

const root = process.argv[2]
const updaterInitPattern = /(const|let|var)\s+appUpdater\s*=\s*new\s+[^;\n]*AppUpdater[^;\n]*\(\)/
const updaterReplacement = `const appUpdater = {
  setAutoUpdate() {},
  cancelDownload() {},
  async checkForUpdates() {
    return {
      currentVersion: app.getVersion(),
      updateInfo: null
    }
  },
  quitAndInstall() {}
}`
const analyticsInitPattern = /analyticsService\.init\(\);?/

function* walk(dir) {
  for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
    const fullPath = path.join(dir, entry.name)
    if (entry.isDirectory()) {
      yield* walk(fullPath)
      continue
    }
    yield fullPath
  }
}

let patchedUpdater = false
let patchedAnalytics = false

for (const file of walk(root)) {
  if (!file.endsWith('.js')) {
    continue
  }

  const text = fs.readFileSync(file, 'utf8')

  let nextText = text

  if (nextText.includes('appUpdater.checkForUpdates') && updaterInitPattern.test(nextText)) {
    nextText = nextText.replace(updaterInitPattern, updaterReplacement)
    patchedUpdater = true
  }

  if (nextText.includes('Analytics service initialized') && analyticsInitPattern.test(nextText)) {
    nextText = nextText.replace(analyticsInitPattern, '')
    patchedAnalytics = true
  }

  if (nextText !== text) {
    fs.writeFileSync(file, nextText)
  }
}

if (!patchedUpdater) {
  throw new Error('packed updater initialization not found in app.asar payload')
}

if (!patchedAnalytics) {
  throw new Error('packed analytics initialization not found in app.asar payload')
}
EOF

  rm -f "${_asar}"
  asar pack "${_extract_dir}" "${_asar}"
}

_record_electron_version() {
  local _binary="$1"
  local _output="$2"
  local _electron_version

  [[ -x "${_binary}" ]] || return 0

  _electron_version="$(strings "${_binary}" 2>/dev/null | sed -n 's|.*Electron/\([0-9][0-9.]*\).*|\1|p' | head -n1 || true)"
  [[ -n "${_electron_version}" ]] || return 0

  install -Dm644 /dev/stdin "${_output}" <<<"${_electron_version}"
}

prepare() {
  cd "$srcdir"
  rm -rf squashfs-root
  chmod +x "${_pkgname}-${pkgver}.AppImage"
  "./${_pkgname}-${pkgver}.AppImage" --appimage-extract >/dev/null
  sed -i \
    -e 's|^Exec=.*|Exec=cherry-studio %U|' \
    -e 's|^Icon=.*|Icon=cherry-studio|' \
    squashfs-root/CherryStudio.desktop
}

package() {
  cd "$srcdir"
  local _install_root="${pkgdir}/opt/${_pkgname}"
  local _asar_extract_dir="${srcdir}/${pkgname}-asar"

  install -dm755 "${_install_root}" "${pkgdir}/usr/share/licenses/${pkgname}"
  install -Dm755 "${pkgname}.sh" "${pkgdir}/usr/bin/${_pkgname}"
  cp -a squashfs-root/. "${_install_root}/"
  chmod 4755 "${_install_root}/chrome-sandbox"
  _remove_updater_metadata "${_install_root}"
  _patch_packed_app "${_install_root}/resources/app.asar" "${_asar_extract_dir}"

  while IFS= read -r -d '' icon; do
    local size
    size="$(basename "$(dirname "$(dirname "$icon")")")"
    install -Dm644 "$icon" "${pkgdir}/usr/share/icons/hicolor/${size}/apps/${_pkgname}.png"
  done < <(find squashfs-root/usr/share/icons/hicolor -type f -path '*/apps/CherryStudio.png' -print0)

  install -Dm644 squashfs-root/usr/share/icons/hicolor/1024x1024/apps/CherryStudio.png "${pkgdir}/usr/share/pixmaps/${_pkgname}.png"
  install -Dm644 squashfs-root/CherryStudio.desktop "${pkgdir}/usr/share/applications/${_pkgname}.desktop"
  install -Dm644 "LICENSE-${pkgver}" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 squashfs-root/LICENSE.electron.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE.electron.txt"
  install -Dm644 squashfs-root/LICENSES.chromium.html "${pkgdir}/usr/share/licenses/${pkgname}/LICENSES.chromium.html"
  _record_electron_version "${_install_root}/CherryStudio" "${_install_root}/electron_version"
  chmod -R u=rwX,go=rX "${pkgdir}"
}
