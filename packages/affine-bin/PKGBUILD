pkgname=affine-bin
_pkgname=AFFiNE
pkgver=0.26.3
pkgrel=1
pkgdesc="Prebuilt collaborative knowledge base and whiteboard desktop application (bundled Electron)"
arch=('x86_64')
url="https://affine.pro/"
_ghurl="https://github.com/toeverything/AFFiNE"
license=('LicenseRef-custom' 'MIT')
options=('!debug' '!strip')
install='affine.install'

provides=("affine=${pkgver}")
conflicts=('affine')

depends=(
  'alsa-lib'
  'at-spi2-core'
  'atk'
  'bash'
  'cairo'
  'cups'
  'dbus'
  'expat'
  'gcc-libs'
  'glib2'
  'glibc'
  'gtk3'
  'libdrm'
  'libnotify'
  'libx11'
  'libxcb'
  'libxcomposite'
  'libxdamage'
  'libxext'
  'libxfixes'
  'libxkbcommon'
  'libxrandr'
  'mesa'
  'nspr'
  'nss'
  'pango'
  'systemd-libs'
  'xdg-utils'
)

optdepends=(
  'gvfs: file trash integration'
  'kde-cli-tools: file trash integration'
  'pulseaudio: audio output support'
  'trash-cli: file trash integration'
)

source=(
  "${pkgname%-bin}-${pkgver}-stable-linux-x64.zip::${_ghurl}/releases/download/v${pkgver}/${pkgname%-bin}-${pkgver}-stable-linux-x64.zip"
  "LICENSE-${pkgver}::https://raw.githubusercontent.com/toeverything/AFFiNE/v${pkgver}/LICENSE"
  "LICENSE-MIT-${pkgver}::https://raw.githubusercontent.com/toeverything/AFFiNE/v${pkgver}/LICENSE-MIT"
  'affine.desktop'
  'affine-flags-wrapper.sh'
  'affine.install'
)
sha256sums=('0ea84444657dd29bf44882b6d3df9aa21f2a33f82effb45f9ae97afe6d991398'
            'c107c8088fe42bce6def95d313cfe7b5984d3bb2c1608b67f855327da45f497b'
            '1cdeca52d4f740361f103926144eb8b3f265975b2337d4e27b3313f72465897f'
            '8ee4d9ae3d73c67e88d0813203240c9b6b381603f9beb3f04641aeff965b801c'
