_remove_updater_metadata() {
  local _root="$1"

  [[ -d "${_root}" ]] || return 0

  # Pacman-managed builds must not point electron-updater at upstream release
  # feeds. Keep AFFiNE's internal updater configuration harmless by removing
  # updater metadata generated by electron-builder/electron-updater.
  find "${_root}" -type f \( \
    -name 'app-update.yml' -o \
    -name 'dev-app-update.yml' -o \
    -name 'latest*.yml' \
  \) -delete 2>/dev/null || true
}

_find_affine_zip_bundle() {
  local _candidate

  for _candidate in \
    "${srcdir}/${_pkgname}-linux-x64" \
    "${srcdir}/${pkgname%-bin}-${pkgver}-stable-linux-x64" \
    "${srcdir}/${pkgname%-bin}-linux-x64"; do
    if [[ -d "${_candidate}" && -d "${_candidate}/resources" ]]; then
      printf '%s\n' "${_candidate}"
      return 0
    fi
  done

  _candidate="$(find "${srcdir}" -mindepth 1 -maxdepth 2 -type f \
    \( -name AFFiNE -o -name affine \) -executable -printf '%h\n' 2>/dev/null | head -n1)"
  if [[ -n "${_candidate}" && -d "${_candidate}/resources" ]]; then
    printf '%s\n' "${_candidate}"
    return 0
  fi

  printf '%s\n' "ERROR: could not locate extracted AFFiNE zip bundle." >&2
  printf '%s\n' "Expected a directory containing resources/ under ${srcdir}." >&2
  return 1
}

package() {
  local _bundle
  local _install_root="${pkgdir}/opt/affine"
  local _app_exec='/opt/affine/affine'
  local _electron_version=''
  local _file
  local _icon=''

  _bundle="$(_find_affine_zip_bundle)"

  install -d "${_install_root}"
  cp -a "${_bundle}/." "${_install_root}/"

  _remove_updater_metadata "${_install_root}"
  find "${_install_root}" -type f -name '*.map' -delete 2>/dev/null || true

  if [[ -x "${_install_root}/AFFiNE" ]]; then
    _app_exec='/opt/affine/AFFiNE'
  elif [[ -x "${_install_root}/affine" ]]; then
    _app_exec='/opt/affine/affine'
  fi

  if [[ -f "${_install_root}/chrome-sandbox" ]]; then
    chmod 4755 "${_install_root}/chrome-sandbox"
  fi

  install -Dm644 "${srcdir}/LICENSE-${pkgver}" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 "${srcdir}/LICENSE-MIT-${pkgver}" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-MIT"
  if [[ -f "${_install_root}/LICENSES.chromium.html" ]]; then
    install -Dm644 "${_install_root}/LICENSES.chromium.html" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSES.chromium.html"
  fi

  for _icon in \
    "${_install_root}/resources/icon.png" \
    "${_install_root}/resources/app/icon.png" \
    "${_install_root}/resources/app/resources/icons/icon_stable_64x64.png" \
    "${_install_root}/resources/app.asar.unpacked/resources/icons/icon_stable_64x64.png"; do
    if [[ -f "${_icon}" ]]; then
      install -Dm644 "${_icon}" "${pkgdir}/usr/share/icons/hicolor/64x64/apps/affine.png"
      install -Dm644 "${_icon}" "${pkgdir}/usr/share/pixmaps/affine.png"
      break
    fi
  done

  install -Dm644 "${srcdir}/affine.desktop" "${pkgdir}/usr/share/applications/affine.desktop"

  if [[ -f "${_install_root}/resources/${pkgname%-bin}.metainfo.xml" ]]; then
    install -Dm644 "${_install_root}/resources/${pkgname%-bin}.metainfo.xml" \
      "${pkgdir}/usr/share/metainfo/affine.metainfo.xml"
  fi

  sed -e "s#@AFFINE_EXEC@#${_app_exec}#g" \
    "${srcdir}/affine-flags-wrapper.sh" >"${srcdir}/affine"

  if grep -q '@[A-Z_][A-Z_]*@' "${srcdir}/affine"; then
    printf '%s\n' "ERROR: unresolved wrapper placeholder(s):"
    grep -n '@[A-Z_][A-Z_]*@' "${srcdir}/affine"
    return 1
  fi

  install -Dm755 "${srcdir}/affine" "${pkgdir}/usr/bin/affine"

  for _file in "${_install_root}/affine" "${_install_root}/AFFiNE"; do
    if [[ -x "${_file}" ]]; then
      _electron_version="$(strings "${_file}" | grep -Pom1 'Electron/[0-9.]+' || true)"
      [[ -n "${_electron_version}" ]] && break
    fi
  done

  _electron_version="${_electron_version#Electron/}"
  if [[ -n "${_electron_version}" ]]; then
    install -Dm644 /dev/stdin "${_install_root}/electron_version" <<<"${_electron_version}"
  fi

}
