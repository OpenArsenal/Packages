+#include "mullvad_country_model.hpp"
+
+#include <QMap>
+#include <QString>
+#include <QTest>
+
+class TestMullvadCountryModel : public QObject
+{
+    Q_OBJECT
+
+private slots:
+    void testUnboundedGrowth()
+    {
+        MullvadCountryModel model;
+
+        QMap<QString, QString> countries40;
+        for (int i = 0; i < 40; ++i) {
+            countries40.insert(QString::number(i), QStringLiteral("Country ") + QString::number(i));
+        }
+
+        QMap<QString, QString> countries41 = countries40;
+        countries41.insert(QStringLiteral("40"), QStringLiteral("Country 40"));
+
+        QMap<QString, QString> countries39 = countries40;
+        countries39.remove(QStringLiteral("39"));
+
+        model.update(countries40);
+        QCOMPARE(model.rowCount(QModelIndex()), 40);
+
+        // Repeatedly oscillate around the baseline size. The broken code keeps
+        // appending during resets, so rowCount() grows instead of stabilizing.
+        for (int i = 0; i < 300; ++i) {
+            model.update(countries41);
+            QCOMPARE(model.rowCount(QModelIndex()), 41);
+
+            model.update(countries39);
+            QCOMPARE(model.rowCount(QModelIndex()), 39);
+
+            model.update(countries40);
+            QCOMPARE(model.rowCount(QModelIndex()), 40);
+        }
+    }
+
+    void testSameSizeDataChangeTriggersReset()
+    {
+        MullvadCountryModel model;
+
+        const QMap<QString, QString> original{{QStringLiteral("de"), QStringLiteral("Germany")},
+                                              {QStringLiteral("se"), QStringLiteral("Sweden")}};
+        const QMap<QString, QString> updated{{QStringLiteral("de"), QStringLiteral("Germany")},
+                                             {QStringLiteral("us"), QStringLiteral("United States")}};
+
+        model.update(original);
+        QCOMPARE(model.rowCount(QModelIndex()), 2);
+        QCOMPARE(model.data(model.index(1, 0), MullvadCountryModel::CountryCode).toString(), QStringLiteral("se"));
+
+        // The earlier size-only fast path missed this mutation entirely,
+        // leaving the UI stale even though the available countries changed.
+        model.update(updated);
+        QCOMPARE(model.rowCount(QModelIndex()), 2);
+        QCOMPARE(model.data(model.index(1, 0), MullvadCountryModel::CountryCode).toString(), QStringLiteral("us"));
+        QCOMPARE(model.data(model.index(1, 0), MullvadCountryModel::CountryName).toString(), QStringLiteral("United States"));
+    }
+};
+
+QTEST_MAIN(TestMullvadCountryModel)
+#include "test_mullvad_country_model.moc"

