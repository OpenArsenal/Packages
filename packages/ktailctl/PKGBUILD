# Maintainer: Okiki <okiki@thunderstrike.co>
pkgname=ktailctl
pkgver='0.21.5'
pkgrel=1
_upstream_dir="KTailctl-$pkgver"
arch=(x86_64 aarch64)
url='https://github.com/f-koehler/KTailctl'
pkgdesc='GUI to monitor and manage Tailscale'
license=(GPL-3.0-only)
depends=(
  breeze-icons
  gcc-libs
  glibc
  hicolor-icon-theme
  kconfig
  kcoreaddons
  kdbusaddons
  kguiaddons
  ki18n
  kirigami
  kirigami-addons
  knotifications
  kwindowsystem
  qqc2-desktop-style
  qt6-base
  qt6-declarative
  qt6-svg
  tailscale
)
optdepends=(
  'qt6-wayland: native Wayland platform plugin support'
)
makedepends=(
  appstream
  cmake
  extra-cmake-modules
  gettext
  go
  nlohmann-json
)
changelog=$pkgname.changelog
install=$pkgname.install

# use any of:
#   gpg --keyserver keyserver.ubuntu.com --search-keys me@fkoehler.org
#   gpg --recv-keys fingerprint_below
#   gpg --import keys/pgp/*.asc
validpgpkeys=(
  # 'C5DC80511469AD81C84E3564D55A35AFB2900A11' # Fabian Köhler <me@fkoehler.org>
)

source=(
  # Stable package: use the release tag archive rather than a VCS source.
  "$pkgname-$pkgver-tag.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz"

  # Arch's Go guidance permits module downloads in prepare(), but this wrapper is
  # already built with `-mod vendor` upstream. Keeping the vendored module tree as
  # an explicit, checksummed source avoids undeclared network fetches and makes
  # the exact Go dependency snapshot part of the package source contract.
  "ktailctl-wrapper-v$pkgver-vendor.tar.gz::$url/releases/download/v$pkgver/ktailctl-wrapper-vendor-v$pkgver.tar.gz"

  # Backport the upstream #481 / PR #483 fix and standalone regressions for both
  # the runaway-growth leak and the same-size stale-UI case. Keeping the tests
  # in the patch makes the release backport self-auditing instead of code-only.
  "$pkgname-mullvad-country-model.patch"
)
sha256sums=('17748d1e9e84d6ea5003111cf083bbe0133c245dc71d8beec652640354f05997'
            '3199b86a912f09d7b3e98bd00a3078b1d599a43a98c4b4b6fd3e032411406f1f'
            '6a7ba1c22885dd0255839ad2e4ac07feed1b7064d5733d84faff095b3adde50f')

_prepare_go_env() {
  # Keep module downloads inside the build dir (avoid polluting ~/go)
  export GOPATH="${srcdir}/.gopath"
  export GOCACHE="${srcdir}/.gocache"
  export GOMODCACHE="${srcdir}/.gomodcache"
}

prepare() {
  cd "$_upstream_dir"
  _prepare_go_env

  # Reuse the declared vendored dependency snapshot rather than running
  # `go mod vendor` here and letting dependency materialization drift at build time.
  rm -rf src/wrapper/vendor
  bsdtar -xf "$srcdir/ktailctl-wrapper-v$pkgver-vendor.tar.gz" -C src/wrapper

  # #481 reports long-running idle OOMs. The upstream diagnosis is a model reset
  # bug in MullvadCountryModel that keeps appending instead of replacing entries.
  # Keep the backport paired with regression coverage for both the leak and the
  # same-size data-change case that previously left the UI stale.
  patch -Np1 -i "$srcdir/$pkgname-mullvad-country-model.patch"

  # Upstream's CMake wrapper has a fallback `go get` step for developer builds.
  # Keep Arch's build graph explicit by vendoring here and disabling that fetch.
  sed -i '/^if(NOT KTAILCTL_FLATPAK_BUILD)$/,/^endif()$/d' src/wrapper/CMakeLists.txt

  # GCC warns about Clang-only `-Wno-*compat` flags in 0.21.5, and the
  # Tailscale constructor initializes peer/account models out of declaration
  # order. Trim that packaging noise without changing runtime behavior.
  sed -i '/-Wno-c99-extensions \\/d; /-Wno-c++98-compat \\/d' CMakeLists.txt
  perl -0pi -e 's@, mPeerModel\(new PeerModel\(this\)\)\n    , mAccountModel\(new AccountModel\(this\)\)@, mAccountModel(new AccountModel(this))\n    , mPeerModel(new PeerModel(this))@' src/tailscale.cpp

  # QT_MESSAGELOGCONTEXT bakes build paths into the package via context.file.
  sed -i '/target_compile_definitions(ktailctl PRIVATE QT_MESSAGELOGCONTEXT)/d' src/CMakeLists.txt
  sed -i '/target_compile_definitions(ktailctl_wrapper_logging PRIVATE QT_MESSAGELOGCONTEXT)/d' src/wrapper/CMakeLists.txt
}

build() {
  cd "$_upstream_dir"
  _prepare_go_env
  
  # CRITICAL: Export CGO flags for Go wrapper hardening
  # Without these, the Go wrapper lacks RELRO and PIE protection
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  
  local cmake_options=(
    -B build
    -S .
    -DCMAKE_BUILD_TYPE=None
    -DCMAKE_INSTALL_PREFIX=/usr
    # KDEInstallDirs owns this path; setting the KDE variable avoids the
    # warning emitted when CMAKE_INSTALL_LIBDIR is overridden too early.
    -DKDE_INSTALL_LIBDIR=lib
    -Wno-dev
  )

  # Upstream's wrapper build already uses `-mod vendor`; keep the package build
  # on that offline path instead of letting CMake fall back to `go get`.
  cmake "${cmake_options[@]}"

  # Build with parallelization
  cmake --build build --parallel
}

check() {
  cd "$_upstream_dir"

  # The backport includes a focused QtTest binary, so run ctest to keep the
  # leak fix and stale-UI fix covered in package builds once deps are present.
  ctest --test-dir build --output-on-failure
}

package() {
  cd "$_upstream_dir"
  
  # Install built files
  DESTDIR="$pkgdir" cmake --install build
  
  # Install license
  install -Dm644 LICENSE.txt -t "$pkgdir/usr/share/licenses/$pkgname/"
}
