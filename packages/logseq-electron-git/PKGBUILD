_nodeversion=22
_electron_version=39

pkgname=logseq-electron-git
pkgver=0.10.15.r24338.gcba65ee479
pkgrel=1
pkgdesc="Privacy-first, open-source platform for knowledge sharing and management (git version; system Electron)"
arch=('x86_64')
url="https://github.com/logseq/logseq"
license=('AGPL-3.0-or-later')
options=('debug' 'strip')

_repo="https://github.com/logseq/logseq.git"
_branch="master"
_dev_release=n # set to y for cljs:dev-release-electron

_pkgsrc="${pkgname}"
_out_path="${_pkgsrc}/static/dist/linux-unpacked"

provides=('logseq')
conflicts=('logseq')
install='logseq.install'

depends=(
  "electron${_electron_version}"
  'bash'
)

makedepends=(
  'asar'
  'clojure'
  'git'
  'nvm'
  'patchelf'
  'python'
  'python-setuptools'
)

source=(
  "${_pkgsrc}::git+${_repo}#branch=${_branch}"
  'logseq.desktop'
  'logseq-flags-wrapper.sh'
  'disable-linux-self-update.patch'
)

sha256sums=('SKIP'
            '01f52e36f035af6393503f39941c0b03b553eae886cdab9e6d0d67e8a15f20df'
            '888d2e76546a501aa0c49487eb203fd0f1f36170edd984e8cf3374378b37d60c'
            '4888172553d920b6f40e65ec24f63b82fbe6f92dca0711c06017d928c85fb6f1')

pkgver() {
  cd "${srcdir}/${_pkgsrc}"

  local _latest_tag _rev_count _commit
  _latest_tag="$(git tag --sort=-v:refname | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | head -n1)"
  _rev_count="$(git rev-list --count HEAD)"
  _commit="$(git rev-parse --short HEAD)"

  printf '%s.r%s.g%s\n' "${_latest_tag:-0.0.0}" "${_rev_count}" "${_commit}"
}

_nvm_env() {
  local _cache_root="${SRCDEST:-${srcdir}}"

  export HOME="${_cache_root}/${pkgname}-node-home"
  export XDG_CACHE_HOME="${HOME}/.cache"
  export XDG_CONFIG_HOME="${HOME}/.config"
  export XDG_DATA_HOME="${HOME}/.local/share"

  export NVM_DIR="${_cache_root}/${pkgname}-node-nvm"
  export COREPACK_HOME="${_cache_root}/${pkgname}-corepack"
  export ELECTRON_SKIP_BINARY_DOWNLOAD=1

  source /usr/share/nvm/init-nvm.sh || [[ $? != 1 ]]
  nvm install "${_nodeversion}"
  nvm use "${_nodeversion}"
  corepack enable
}

_pnpm_env() {
  corepack prepare "$(node -p "require('./package.json').packageManager")" --activate
}

_fix_system_electron_cli_path() {
  local _root="$1"
  local _files=()
  local _file

  [[ -d "${_root}" ]] || return 0

  mapfile -d '' _files < <(LC_ALL=C grep -IlRZ -F 'logseq-cli.js' "${_root}" 2>/dev/null || true)
  ((${#_files[@]} == 0)) && return 0

  for _file in "${_files[@]}"; do
    python - "${_file}" <<'PYTHON_EOF'
from pathlib import Path
import sys

path = Path(sys.argv[1])
data = path.read_bytes()

if b'logseq-cli.js' not in data:
    raise SystemExit(0)

# With system Electron, process.resourcesPath points at /usr/lib/electron*/resources,
# not the packaged Logseq resources dir.  Use dirname(app.getAppPath())
# so the existing js/logseq-cli.js join resolves under /usr/lib/logseq/app.
old = b'process.resourcesPath'
new = b'require("path").dirname(require("electron").app.getAppPath())'

if old in data:
    path.write_bytes(data.replace(old, new))
PYTHON_EOF
  done
}

_install_system_electron_app() {
  local _bundle="$1"
  local _app_dir="$2"

  rm -rf "${_app_dir}"
  install -d "${_app_dir}"

  if [[ -d "${_bundle}/resources/app" ]]; then
    cp -aL "${_bundle}/resources/app/." "${_app_dir}/"
  elif [[ -f "${_bundle}/resources/app.asar" ]]; then
    asar extract "${_bundle}/resources/app.asar" "${_app_dir}"
  else
    printf '%s\n' "ERROR: could not locate Logseq Electron app payload."
    printf 'Checked:\n  %s\n  %s\n' \
      "${_bundle}/resources/app" \
      "${_bundle}/resources/app.asar"
    return 1
  fi

  if [[ -d "${_bundle}/resources/app.asar.unpacked" ]]; then
    cp -aL "${_bundle}/resources/app.asar.unpacked/." "${_app_dir}/"
  fi
}

prepare() {
  _nvm_env

  local _electron_version_full
  _electron_version_full="$(<"/usr/lib/electron${_electron_version}/version")"

  cd "${srcdir}/${_pkgsrc}"
  _pnpm_env

  patch -Np1 -i "${srcdir}/disable-linux-self-update.patch"

  export ELECTRON_OVERRIDE_DIST_PATH="/usr/lib/electron${_electron_version}"

  sed -E \
    -e 's#("electron"): "[^"]+",#\1: "'"${_electron_version_full}"'",#' \
    -e 's#pnpm install --frozen-lockfile#pnpm install --no-frozen-lockfile#g' \
    -i resources/package.json gulpfile.js

  corepack pnpm install --force
  corepack pnpm run gulp:build

  clojure -P -M:cljs
}

build() {
  _nvm_env

  cd "${srcdir}/${_pkgsrc}"
  _pnpm_env

  export ELECTRON_OVERRIDE_DIST_PATH="/usr/lib/electron${_electron_version}"

  if [[ "${_dev_release}" == y ]]; then
    corepack pnpm run cljs:dev-release-electron
  else
    corepack pnpm run cljs:release-electron
  fi

  corepack pnpm run db-worker-node:bundle
  corepack pnpm run webpack-app-build
  corepack pnpm exec gulp electronMaker
}

package() {
  local _electron_version_full
  local _bundle="${srcdir}/${_out_path}"
  local _app_dir="${pkgdir}/usr/lib/logseq/app"
  local _dugite_gitcore="${_app_dir}/node_modules/dugite/git/libexec/git-core"
  local _file

  _electron_version_full="$(<"/usr/lib/electron${_electron_version}/version")"

  _install_system_electron_app "${_bundle}" "${_app_dir}"

  # Logseq's CLI launcher installer still checks the packaged app.asar path.
  # The system-Electron package intentionally runs an unpacked app directory, so
  # provide a compatibility path for code that probes resources/app.asar/js/...
  # without changing the runtime entry point used by the wrapper.
  rm -rf "${pkgdir}/usr/lib/logseq/app.asar"
  ln -s app "${pkgdir}/usr/lib/logseq/app.asar"

  rm -rf "${_app_dir}/node_modules/electron-deeplink/build"

  grep -IlRZ -F "${srcdir}" "${_app_dir}" 2>/dev/null |
    xargs -0 -r sed -i "s#${srcdir}#/usr/src/debug/${pkgname}#g"

  _fix_system_electron_cli_path "${_app_dir}"

  if [[ -d "${_dugite_gitcore}" ]]; then
    while IFS= read -r -d '' _file; do
      if [[ "$(patchelf --print-rpath "${_file}" 2>/dev/null)" == '/tmp/build/curl/lib' ]]; then
        patchelf --remove-rpath "${_file}"
      fi
    done < <(find "${_dugite_gitcore}" -type f -print0)
  fi

  install -Dm644 "${srcdir}/${_pkgsrc}/resources/icons/logseq.png" \
    "${pkgdir}/usr/share/pixmaps/logseq.png"
  install -Dm644 "${srcdir}/logseq.desktop" \
    "${pkgdir}/usr/share/applications/logseq.desktop"

  sed \
    -e "s#@ELECTRON_CMD@#/usr/bin/electron${_electron_version}#g" \
    -e "s#@LOGSEQ_APP@#/usr/lib/logseq/app#g" \
    "${srcdir}/logseq-flags-wrapper.sh" >"${srcdir}/logseq"

  install -Dm755 "${srcdir}/logseq" "${pkgdir}/usr/bin/logseq"
  install -Dm644 /dev/stdin "${pkgdir}/usr/lib/logseq/electron_version" <<<"${_electron_version_full}"
}
