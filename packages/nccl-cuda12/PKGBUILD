pkgname=nccl-cuda12
_pkgname=nccl
pkgver=2.29.7
_upstr_pkgrel=1
pkgrel=1
pkgdesc='Library for NVIDIA multi-GPU and multi-node collective communication primitives (built against cuda12)'
arch=(x86_64)
url='https://developer.nvidia.com/nccl/'
license=(BSD-3-Clause)

_cuda_pkg=cuda12
_cuda_root=/opt/cuda
# Set this to 14 or 13 depending on which compiler you want NCCL to use.
_gcc_major=14

provides=("nccl=${pkgver}")
conflicts=(nccl)
depends=(
  glibc
  libgcc
  libstdc++
  "${_cuda_pkg}"
)
makedepends=(
  "gcc${_gcc_major}"
  git
  python
  "${_cuda_pkg}"
)
optdepends=('nccl-tests-cuda12: NCCL validation and performance tests')
source=("git+https://github.com/NVIDIA/nccl.git#tag=v${pkgver}-${_upstr_pkgrel}")
sha256sums=('SKIP')

prepare() {
  cd "${srcdir}/${_pkgname}"

  # Rename BUILDDIR Makefile variable to avoid conflict with makepkg's BUILDDIR.
  local _file
  local _filelist
  _filelist="$(find . -type f -exec grep -l 'BUILDDIR' {} +)"
  for _file in ${_filelist}; do
    sed -i 's/BUILDDIR/_BUILDPATH/g' "${_file}"
  done
}

build() {
  cd "${srcdir}/${_pkgname}"

  local _hostcc=
  local _hostcxx=
  local _candidate=

  for _candidate in "/usr/bin/gcc-${_gcc_major}" "/usr/bin/gcc${_gcc_major}"; do
    if [[ -x "${_candidate}" ]]; then
      _hostcc="${_candidate}"
      break
    fi
  done

  for _candidate in "/usr/bin/g++-${_gcc_major}" "/usr/bin/g++${_gcc_major}"; do
    if [[ -x "${_candidate}" ]]; then
      _hostcxx="${_candidate}"
      break
    fi
  done

  if [[ -z "${_hostcc}" || -z "${_hostcxx}" ]]; then
    printf 'Missing host compiler for gcc%s\n' "${_gcc_major}" >&2
    printf 'Tried: /usr/bin/gcc-%s, /usr/bin/gcc%s, /usr/bin/g++-%s, /usr/bin/g++%s\n' \
      "${_gcc_major}" "${_gcc_major}" "${_gcc_major}" "${_gcc_major}" >&2
    return 1
  fi

  export CC="${_hostcc}"
  export CXX="${_hostcxx}"
  export NVCC_CCBIN="${_hostcc}"

  # https://docs.nvidia.com/cuda/turing-compatibility-guide/index.html
  # Specify as follows:
  # PTX virtual arch:  -gencode=arch=compute_XX,code=compute_XX
  # binary cubin arch: -gencode=arch=compute_XX,code=sm_XX
  # We provide binary support on all arches, no PTX is needed
  # except the newest PTX target kept for future compatibility.
  export NVCC_GENCODE="-gencode=arch=compute_52,code=sm_52 \
                       -gencode=arch=compute_53,code=sm_53 \
                       -gencode=arch=compute_60,code=sm_60 \
                       -gencode=arch=compute_61,code=sm_61 \
                       -gencode=arch=compute_62,code=sm_62 \
                       -gencode=arch=compute_70,code=sm_70 \
                       -gencode=arch=compute_72,code=sm_72 \
                       -gencode=arch=compute_75,code=sm_75 \
                       -gencode=arch=compute_80,code=sm_80 \
                       -gencode=arch=compute_86,code=sm_86 \
                       -gencode=arch=compute_87,code=sm_87 \
                       -gencode=arch=compute_89,code=sm_89 \
                       -gencode=arch=compute_90,code=sm_90 \
                       -gencode=arch=compute_90a,code=sm_90a \
                       -gencode=arch=compute_100,code=sm_100 \
                       -gencode=arch=compute_100a,code=sm_100a \
                       -gencode=arch=compute_101,code=sm_101 \
                       -gencode=arch=compute_101a,code=sm_101a \
                       -gencode=arch=compute_120,code=sm_120 \
                       -gencode=arch=compute_120a,code=sm_120a \
                       -gencode=arch=compute_120,code=compute_120"

  # Do not use cudart_static; it can trigger the enhcompat issue.
  export CUDARTLIB=cudart

  # Preserve usable static objects when global LTO is enabled.
  export CXXFLAGS+=" -ffat-lto-objects"

  make \
    CUDA_HOME="${_cuda_root}" \
    PREFIX=/usr \
    CC="${CC}" \
    CXX="${CXX}" \
    src.build
}

package() {
  cd "${srcdir}/${_pkgname}"

  make \
    CUDA_HOME="${_cuda_root}" \
    PREFIX="${pkgdir}/usr" \
    install

  rm -f "${pkgdir}"/usr/lib/*.a
  install -Dm644 LICENSE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE.txt"
}
