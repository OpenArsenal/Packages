 (defn setup-updater! [^js win]
   ;; manual/auto updater
-  (init-updater {:repo   "logseq/logseq"
-                 :win    win}))
+  (let [platform (.-platform js/process)
+        appimage? (some? (.. js/process -env -APPIMAGE))]
+    ;; Pacman-managed Linux builds should not enter the AppImage updater path.
+    ;; Keep updater support for Windows/macOS, and for real AppImage runs.
+    (when (or (not= platform "linux") appimage?)
+      (init-updater {:repo   "logseq/logseq"
+                     :win    win}))))
 
