# Maintainer: Okiki Ojo <okiki@thunderstrike.co>
_pkgname=figma-linux
_electronversion=30
pkgname=${_pkgname}-git
pkgver=0.11.4.r10.gd9a7a03
pkgrel=6
pkgdesc="Unofficial Electron-based Figma desktop client for Linux (bundled Electron, git HEAD)"
arch=('x86_64' 'aarch64')
url="https://github.com/Figma-Linux/figma-linux"
license=('GPL-2.0-only')

provides=('figma-linux')
conflicts=('figma-linux' 'figma-linux-electron' 'figma-linux-electron-git')

options=('!debug' '!strip')
depends=('bash' 'gtk3' 'nss' 'alsa-lib' 'hicolor-icon-theme')
makedepends=('git' 'nodejs' 'npm')
optdepends=(
  'xdg-utils: Open links and files'
  'libnotify: Desktop notifications'
)

source=(
  "${_pkgname}.git::git+${url}.git"
  "figma-linux.desktop"
  "figma-linux.sh"
)

sha256sums=('SKIP'
            '5029d26b935d5527c9a71f1a3fe81264f92a3d4a9f1c3b71296623d8d9d1edb2'
            '7d939f619daa3c1f1d45d7bd9274a2161417e951695ed2514d573bbf09552586')

_record_electron_version() {
  local _binary="$1"
  local _output="$2"
  local _electron_version

  [[ -x "${_binary}" ]] || return 0

  _electron_version="$(strings "${_binary}" 2>/dev/null | sed -n 's|.*Electron/\([0-9][0-9.]*\).*|\1|p' | head -n1 || true)"
  [[ -n "${_electron_version}" ]] || return 0

  install -Dm644 /dev/stdin "${_output}" <<<"${_electron_version}"
}

pkgver() {
  cd "${srcdir}/${_pkgname}.git"
  
  git describe --long --tags --abbrev=7 2>/dev/null \
    | sed 's/^v//; s/\([^-]*-g\)/r\1/; s/-/./g' \
    || printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
}

_configure_npm_mirrors() {
	# This function is intentionally "opt-in".
	# If the builder doesn't set any env vars, it does nothing.
	#
	# Supported env vars:
	# - NPM_CONFIG_REGISTRY
	# - ELECTRON_MIRROR
	# - ELECTRON_BUILDER_BINARIES_MIRROR
	#
	# These mirror vars are respected by npm and/or electron-builder tooling.
	# We also write them into .npmrc for visibility and consistency.

	if [[ -n "${NPM_CONFIG_REGISTRY:-}" ]]; then
		printf 'registry=%s\n' "${NPM_CONFIG_REGISTRY}" >> .npmrc
	fi

	if [[ -n "${ELECTRON_MIRROR:-}" ]]; then
		printf 'electron_mirror=%s\n' "${ELECTRON_MIRROR}" >> .npmrc
	fi

	if [[ -n "${ELECTRON_BUILDER_BINARIES_MIRROR:-}" ]]; then
		printf 'electron_builder_binaries_mirror=%s\n' "${ELECTRON_BUILDER_BINARIES_MIRROR}" >> .npmrc
	fi
}

_assert_upstream_electron_major() {
  local _electron_pkg_major

  _electron_pkg_major="$(node -e 'const pkg = require("./package.json"); const value = pkg.devDependencies?.electron ?? pkg.dependencies?.electron ?? ""; process.stdout.write(String(value));' | tr -d '^~<>= ' | cut -d. -f1)"
  if [[ -z "${_electron_pkg_major}" ]]; then
    echo 'Could not determine Electron major from package.json.' >&2
    exit 1
  fi

  if [[ "${_electron_pkg_major}" != "${_electronversion}" ]]; then
    echo "Electron major ${_electron_pkg_major} does not match expected ${_electronversion}." >&2
    exit 1
  fi
}

_scrub_srcdir_references() {
  local _root="$1"

  [[ -d "${_root}" ]] || return 0

  grep -IlRZ -F "${srcdir}" "${_root}" 2>/dev/null |
    xargs -0 -r sed -i "s#${srcdir}#/usr/src/debug/${pkgname}#g"
}

_assert_no_srcdir_references() {
  local _hits=()

  mapfile -d '' _hits < <(LC_ALL=C grep -aRZlF "${srcdir}" "${pkgdir}" 2>/dev/null || true)
  if ((${#_hits[@]})); then
    printf '%s\n' 'ERROR: package still contains references to $srcdir:' >&2
    printf '  %s\n' "${_hits[@]#${pkgdir}/}" >&2
    return 1
  fi
}

_remove_updater_metadata() {
  local _root="$1"

  [[ -d "${_root}" ]] || return 0

  find "${_root}" -type f \( \
    -name 'app-update.yml' -o \
    -name 'dev-app-update.yml' -o \
    -name 'latest*.yml' \
  \) -delete 2>/dev/null || true
}

build() {
  cd "${srcdir}/${_pkgname}.git"

  export HOME="${srcdir}/.home"
  export npm_config_cache="${srcdir}/.npm-cache"

	# Recreate .npmrc every build so you don't accumulate duplicated lines
	: > .npmrc
	printf 'cache=%s\n' "${npm_config_cache}" >> .npmrc

	# 👇 Apply opt-in mirrors (only if env vars exist)
	_configure_npm_mirrors
  _assert_upstream_electron_major

  git submodule update --init --recursive || true

  if [[ ! -f package-lock.json ]]; then
    echo 'Missing package-lock.json; refusing non-deterministic npm install fallback.' >&2
    exit 1
  fi

  npm ci --no-audit --no-fund

	# Build application
  npm run build

	# Create Linux bundle with electron-builder
  npm exec -c "electron-builder --linux dir --publish never --config=config/builder.json"
}

package() {
  cd "${srcdir}/${_pkgname}.git"

  local _out=""
  local _install_root="${pkgdir}/opt/${_pkgname}"
  _out="$(find . -maxdepth 3 -type d -name 'linux-*unpacked' 2>/dev/null | head -n 1 || true)"

  if [[ -z "${_out}" || ! -d "${_out}" ]]; then
    echo "ERROR: Could not find linux-*unpacked output directory" >&2
    return 1
  fi
	# Install entire bundled application (includes electron runtime)
  install -d "${_install_root}"
  cp -a "${_out}/." "${_install_root}/"
	_remove_updater_metadata "${_install_root}"
	_scrub_srcdir_references "${_install_root}"

	# Create predictable executable name if needed
  if [[ -x "${_install_root}/${_pkgname}" && ! -e "${_install_root}/${_pkgname}" ]]; then
    ln -s "${_pkgname}" "${_install_root}/${_pkgname}"
  fi

	# Install wrapper, desktop entry, license
  install -Dm755 "${srcdir}/figma-linux.sh" "${pkgdir}/usr/bin/${_pkgname}"
  install -Dm644 "${srcdir}/figma-linux.desktop" "${pkgdir}/usr/share/applications/${_pkgname}.desktop"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${_pkgname}/LICENSE"
  _record_electron_version "${_install_root}/${_pkgname}" "${_install_root}/electron_version"

	# Install icons from upstream repo (not from our sources)
  local -a _icon_sizes=(24x24 32x32 36x36 48x48 64x64 72x72 96x96 128x128 192x192 256x256 384x384 512x512 scalable)
  
  for _size in "${_icon_sizes[@]}"; do
    for _src in "lib/icons/${_size}."*; do
      [[ -e "${_src}" ]] || continue
      local _ext="${_src##*.}"
      install -Dm644 "${_src}" \
        "${pkgdir}/usr/share/icons/hicolor/${_size}/apps/${_pkgname}.${_ext}"
    done
  done
	_assert_no_srcdir_references
  chmod -R u=rwX,go=rX "${pkgdir}"
}
