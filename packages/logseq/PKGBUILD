_nodeversion=22

pkgname=logseq
pkgver=0.10.15
pkgrel=1
pkgdesc="Privacy-first, open-source platform for knowledge sharing and management (bundled Electron)"
arch=('x86_64')
url="https://github.com/logseq/logseq"
license=('AGPL-3.0-or-later')
options=('!debug')

_pkgsrc="logseq-${pkgver}"
_out_path="${_pkgsrc}/static/out/Logseq-linux-x64"

conflicts=(
  'logseq-git'
  'logseq-electron'
  'logseq-electron-git'
)
install='logseq.install'

depends=(
  'alsa-lib'
  'at-spi2-core'
  'bash'
  'cairo'
  'curl'
  'dbus'
  'expat'
  'glib2'
  'gtk3'
  'libcups'
  'libx11'
  'libxcb'
  'libxcomposite'
  'libxdamage'
  'libxext'
  'libxfixes'
  'libxkbcommon'
  'libxrandr'
  'mesa'
  'nspr'
  'nss'
  'pango'
  'systemd-libs'
  'zlib'
)

makedepends=(
  'asar'
  'clojure'
  'git'
  'nvm'
  'patchelf'
  'python'
  'python-setuptools'
  'yarn'
)

source=(
  "logseq-${pkgver}.tar.gz::${url}/archive/refs/tags/${pkgver}.tar.gz"
  'logseq.desktop'
  'logseq-flags-wrapper.sh'
  'disable-linux-self-update.patch'
)

sha256sums=('ff5d28c82027d3193cf75d9d0cc8eefa00a7f054234c7f164c29845580a1cccc'
            '01f52e36f035af6393503f39941c0b03b553eae886cdab9e6d0d67e8a15f20df'
            'f69f8bbc8a56381b7ad67dd4b7ba1479ef7586aa55893ddd60a0b247ef79a49b'
            'dbadbfec1d4b6341c21e14244f7d43b21c115ee056ac1edc843812b0bded41c3')

_nvm_env() {
  local _cache_root="${SRCDEST:-${srcdir}}"

  export HOME="${_cache_root}/${pkgname}-node-home"
  export XDG_CACHE_HOME="${HOME}/.cache"
  export XDG_CONFIG_HOME="${HOME}/.config"
  export XDG_DATA_HOME="${HOME}/.local/share"

  export NVM_DIR="${_cache_root}/${pkgname}-node-nvm"

  source /usr/share/nvm/init-nvm.sh || [[ $? != 1 ]]
  nvm install "${_nodeversion}"
  nvm use "${_nodeversion}"
}

_scrub_srcdir_references() {
  local _root="$1"

  [[ -d "${_root}" ]] || return 0

  grep -IlRZ -F "${srcdir}" "${_root}" 2>/dev/null |
    xargs -0 -r sed -i "s#${srcdir}#/usr/src/debug/${pkgname}#g"
}

prepare() {
  _nvm_env

  cd "${srcdir}/${_pkgsrc}"

  patch -Np1 -i "${srcdir}/disable-linux-self-update.patch"

  yarn install --force --production=false --non-interactive
  yarn gulp:build

  cd static
  yarn install --force --production=false --non-interactive

  cd ..
  clojure -P -M:cljs
}

build() {
  _nvm_env

  cd "${srcdir}/${_pkgsrc}"

  yarn cljs:release-electron

  cd static
  test -x node_modules/.bin/electron-forge
  ./node_modules/.bin/electron-forge package
}

package() {
  local _bundle="${srcdir}/${_out_path}"
  local _install_root="${pkgdir}/opt/logseq"
  local _app_asar="${_install_root}/resources/app.asar"
  local _app_asar_stage="${srcdir}/.app-asar-${pkgname}"
  local _app_exec="/opt/logseq/Logseq"
  local _electron_version=""
  local _file _gitcore

  install -d "${_install_root}"
  cp -a "${_bundle}/." "${_install_root}/"

  rm -rf \
    "${_install_root}/resources/app/node_modules/electron-deeplink/build" \
    "${_install_root}/resources/app.asar.unpacked/node_modules/electron-deeplink/build"

  find "${_install_root}/resources" -type f -name '*.map' -delete 2>/dev/null || true

  if [[ -f "${_app_asar}" ]]; then
    rm -rf "${_app_asar_stage}"
    asar extract "${_app_asar}" "${_app_asar_stage}"
    find "${_app_asar_stage}" -type f -name '*.map' -delete
    _scrub_srcdir_references "${_app_asar_stage}"
    asar pack "${_app_asar_stage}" "${_app_asar}"
    rm -rf "${_app_asar_stage}"
  fi

  _scrub_srcdir_references "${_install_root}/resources/app"
  _scrub_srcdir_references "${_install_root}/resources/app.asar.unpacked"

  for _gitcore in \
    "${_install_root}/resources/app.asar.unpacked/node_modules/dugite/git/libexec/git-core" \
    "${_install_root}/resources/app/node_modules/dugite/git/libexec/git-core"; do
    [[ -d "${_gitcore}" ]] || continue
    while IFS= read -r -d '' _file; do
      if [[ "$(patchelf --print-rpath "${_file}" 2>/dev/null)" == '/tmp/build/curl/lib' ]]; then
        patchelf --remove-rpath "${_file}"
      fi
    done < <(find "${_gitcore}" -type f -print0)
  done

  install -Dm644 "${srcdir}/${_pkgsrc}/resources/icons/logseq.png" \
    "${pkgdir}/usr/share/pixmaps/logseq.png"
  install -Dm644 "${srcdir}/logseq.desktop" \
    "${pkgdir}/usr/share/applications/logseq.desktop"

  if [[ -x "${_install_root}/logseq" ]]; then
    _app_exec="/opt/logseq/logseq"
  fi

  sed -e "s#@LOGSEQ_EXEC@#${_app_exec}#g" \
    "${srcdir}/logseq-flags-wrapper.sh" >"${srcdir}/logseq"

  install -Dm755 "${srcdir}/logseq" "${pkgdir}/usr/bin/logseq"

  for _file in "${_install_root}/Logseq" "${_install_root}/logseq"; do
    if [[ -x "${_file}" ]]; then
      _electron_version="$(strings "${_file}" | grep -Pom1 'Electron/[0-9.]+' || true)"
      [[ -n "${_electron_version}" ]] && break
    fi
  done

  _electron_version="${_electron_version#Electron/}"
  if [[ -n "${_electron_version}" ]]; then
    install -Dm644 /dev/stdin "${_install_root}/electron_version" <<<"${_electron_version}"
  fi

  chmod -R u=rwX,go=rX "${pkgdir}"
}
