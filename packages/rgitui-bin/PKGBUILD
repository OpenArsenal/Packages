package() {
  cd "${srcdir}"

  install -Dm644 "${_name}-icon-16-${pkgver}.png" "${pkgdir}/usr/share/icons/hicolor/16x16/apps/${_name}.png"
  install -Dm644 "${_name}-icon-32-${pkgver}.png" "${pkgdir}/usr/share/icons/hicolor/32x32/apps/${_name}.png"
  install -Dm644 "${_name}-icon-48-${pkgver}.png" "${pkgdir}/usr/share/icons/hicolor/48x48/apps/${_name}.png"
  install -Dm644 "${_name}-icon-256-${pkgver}.png" "${pkgdir}/usr/share/icons/hicolor/256x256/apps/${_name}.png"
  install -Dm644 "${_name}-icon-512-${pkgver}.png" "${pkgdir}/usr/share/icons/hicolor/512x512/apps/${_name}.png"

  install -Dm644 "${_name}-${pkgver}.desktop" "${pkgdir}/usr/share/applications/${_name}.desktop"
  install -Dm644 "com.${_name}.app-${pkgver}.metainfo.xml" "${pkgdir}/usr/share/metainfo/com.${_name}.app.metainfo.xml"

  install -Dm755 "${_name}/${_name}" "${pkgdir}/usr/bin/${_name}"
  install -Dm644 "${_name}/README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 "${_name}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
