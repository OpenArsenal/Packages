pkgrel=1
pkgdesc="A GPU-accelerated desktop Git client built in Rust with GPUI (prebuilt release)"
arch=('x86_64')
url='https://github.com/noahbclarkson/rgitui'
license=('MIT')
provides=("${_name}=${pkgver}")
conflicts=('rgitui' 'rgitui-git')
depends=('glibc' 'hicolor-icon-theme' 'libgcc' 'libxcb' 'libxkbcommon' 'libxkbcommon-x11' 'openssl' 'zlib')
options=('!strip')

_gitversion="v${pkgver}"
