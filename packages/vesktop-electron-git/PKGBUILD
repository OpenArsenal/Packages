  'libxkbcommon'
  'libxrandr'
  'mesa'
  'nspr'
  'nss'
  'pango'
  'systemd-libs'
  'zlib'
)

makedepends=(
  'git'
  'nvm'
  'pkgconf'
  'pnpm'
  'python'
)

source=(
  "${_pkgsrc}::git+${_repo}#branch=${_branch}"
  'vesktop.desktop'
  'vesktop-flags-wrapper.sh'
  'electron-builder-config.cjs'
  '1242.patch'
  '1251.patch'
)

